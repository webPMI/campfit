---
interface Props {
  /** Número de líneas de skeleton */
  lines?: number;
  /** Ancho de cada línea (array de clases Tailwind) */
  widths?: string[];
  /** Clases adicionales para el contenedor */
  class?: string;
  /** Tipo de skeleton: 'card' | 'list' | 'text' | 'avatar' */
  type?: 'card' | 'list' | 'text' | 'avatar';
}

const { lines = 3, widths = ['w-full', 'w-3/4', 'w-1/2'], type = 'text', class: className = '' } = Astro.props;

function getWidth(index: number): string {
  return widths[index] || widths[widths.length - 1] || 'w-full';
}
---

{
  type === 'card' && (
    <div class={`animate-pulse rounded-xl border border-zinc-800/40 bg-zinc-900/40 p-6 backdrop-blur-sm ${className}`}>
      <div class="flex items-center gap-4">
        <div class="h-12 w-12 rounded-full bg-zinc-800"></div>
        <div class="flex-1 space-y-2">
          <div class="h-4 w-1/3 rounded bg-zinc-800"></div>
          <div class="h-3 w-1/2 rounded bg-zinc-800/60"></div>
        </div>
      </div>
      <div class="mt-4 space-y-2">
        {Array.from({ length: lines }).map((_, i) => (
          <div class={`h-3 rounded bg-zinc-800/60 ${getWidth(i)}`}></div>
        ))}
      </div>
    </div>
  )
}

{
  type === 'list' && (
    <div class={`animate-pulse space-y-3 ${className}`}>
      {Array.from({ length: lines }).map((_, i) => (
        <div class="flex items-center gap-3 rounded-xl bg-zinc-900/40 p-4 border border-zinc-800/40">
          <div class="h-10 w-10 rounded-full bg-zinc-800"></div>
          <div class="flex-1 space-y-1.5">
            <div class={`h-3.5 rounded bg-zinc-800 ${getWidth(i)}`}></div>
            <div class="h-3 w-1/4 rounded bg-zinc-800/60"></div>
          </div>
        </div>
      ))}
    </div>
  )
}

{
  type === 'avatar' && (
    <div class={`animate-pulse flex items-center gap-3 ${className}`}>
      <div class="h-10 w-10 rounded-full bg-zinc-800"></div>
      <div class="flex-1 space-y-1.5">
        <div class="h-3.5 w-1/3 rounded bg-zinc-800"></div>
        <div class="h-3 w-1/4 rounded bg-zinc-800/60"></div>
      </div>
    </div>
  )
}

{
  type === 'text' && (
    <div class={`animate-pulse space-y-2 ${className}`}>
      {Array.from({ length: lines }).map((_, i) => (
        <div class={`h-3 rounded bg-zinc-800/60 ${getWidth(i)}`}></div>
      ))}
    </div>
  )
}
