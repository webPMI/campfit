---
import ClientLayout from '@/layouts/ClientLayout.astro';
import { translations, type Language } from '@/i18n/translations';

const lang = (Astro.url.searchParams.get('lang') as Language) || 'es';
const t = (key: string) => translations[lang]?.[key] || translations['es']?.[key] || key;
---

<ClientLayout>
  <div id="loadingScreen" class="flex min-h-screen items-center justify-center">
    <div class="text-center animate-fade-in">
      <div class="mx-auto h-10 w-10 animate-spin rounded-full border-4 border-zinc-700 border-t-emerald-400"></div>
      <p id="loadingText" class="mt-4 text-sm text-zinc-500">{t('dashboard.loading')}</p>
    </div>
  </div>

  <div id="dietsContent" class="hidden">
    <main class="mx-auto max-w-4xl px-4 py-6">
      <div class="animate-fade-in space-y-6">
        <!-- Header -->
        <div>
          <h2 class="text-xl font-bold">Plan Nutricional</h2>
          <p class="mt-1 text-sm text-zinc-500">Sigue tu plan de alimentación personalizado</p>
        </div>

        <!-- Diet Card -->
        <div id="dietCard" class="hidden card-glow rounded-2xl border border-zinc-800/60 bg-zinc-900/80 p-6 backdrop-blur-xl">
          <div class="flex items-center justify-between mb-4">
            <div>
              <h3 id="dietName" class="text-lg font-bold text-zinc-100"></h3>
              <span id="dietType" class="mt-1 inline-block rounded-full bg-emerald-500/10 px-3 py-1 text-xs font-medium text-emerald-400"></span>
            </div>
            <p id="dietCalories" class="text-sm text-zinc-500"></p>
          </div>

          <div class="space-y-3" id="mealsList">
            <!-- Meals rendered by JS -->
          </div>

          <!-- Totals -->
          <div id="mealTotals" class="mt-6 rounded-xl border border-zinc-800/40 bg-zinc-900/40 p-4">
            <p class="text-xs font-medium text-zinc-500 uppercase tracking-wider">Totales del día</p>
            <div class="mt-2 flex flex-wrap gap-4 text-sm">
              <span class="text-zinc-300">Cal: <strong id="totalCal" class="text-emerald-400">0</strong></span>
              <span class="text-zinc-300">P: <strong id="totalProtein" class="text-emerald-400">0</strong>g</span>
              <span class="text-zinc-300">C: <strong id="totalCarbs" class="text-emerald-400">0</strong>g</span>
              <span class="text-zinc-300">G: <strong id="totalFat" class="text-emerald-400">0</strong>g</span>
            </div>
          </div>
        </div>

        <!-- Empty State -->
        <div id="emptyState" class="flex flex-col items-center justify-center rounded-2xl border border-dashed border-zinc-800/60 bg-zinc-900/40 p-12 text-center">
          <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-zinc-800/50">
            <svg class="h-8 w-8 text-zinc-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8.25v-1.5m0 1.5c-1.355 0-2.697.056-4.024.166C6.845 8.51 6 9.473 6 10.608v2.513m6-4.871c1.355 0 2.697.056 4.024.166C17.155 8.51 18 9.473 18 10.608v2.513M15 8.25v-1.5m-6 1.5v-1.5m12 9.75-1.5.75a3.354 3.354 0 0 1-3 0 3.354 3.354 0 0 0-3 0 3.354 3.354 0 0 1-3 0 3.354 3.354 0 0 0-3 0 3.354 3.354 0 0 1-3 0L3 16.5m15-3.38a48.474 48.474 0 0 0-6-.37c-2.032 0-4.034.125-6 .37m12 0c.39.049.777.102 1.163.16 1.07.16 1.837 1.094 1.837 2.175v5.169c0 .621-.504 1.125-1.125 1.125H4.125A1.125 1.125 0 0 1 3 20.625v-5.17c0-1.08.768-2.014 1.837-2.174A47.78 47.78 0 0 1 6 13.12M12.265 3.11a.375.375 0 1 1-.53 0L12 2.845l.265.265Zm-3 0a.375.375 0 1 1-.53 0L9 2.845l.265.265Zm6 0a.375.375 0 1 1-.53 0L15 2.845l.265.265Z" />
            </svg>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-zinc-400">{t('client.no.diet')}</h3>
          <p class="mt-2 text-sm text-zinc-600">Tu entrenador asignará un plan nutricional personalizado.</p>
        </div>
      </div>
    </main>
  </div>
</ClientLayout>

<script>
  import { authService } from '@/services/authService';
  import { setUser } from '@/stores/authStore';
  import { db } from '@/lib/firebase';
  import { doc, getDoc } from 'firebase/firestore';
  import { subscribeToDiets } from '@/lib/client/dietService';
  import { t } from '@/i18n/client';

  const loadingScreen = document.getElementById('loadingScreen')!;
  const loadingText = document.getElementById('loadingText')!;
  const dietsContent = document.getElementById('dietsContent')!;
  const dietCard = document.getElementById('dietCard')!;
  const emptyState = document.getElementById('emptyState')!;
  const dietName = document.getElementById('dietName')!;
  const dietType = document.getElementById('dietType')!;
  const dietCalories = document.getElementById('dietCalories')!;
  const mealsList = document.getElementById('mealsList')!;
  const totalCal = document.getElementById('totalCal')!;
  const totalProtein = document.getElementById('totalProtein')!;
  const totalCarbs = document.getElementById('totalCarbs')!;
  const totalFat = document.getElementById('totalFat')!;

  loadingText.textContent = t('dashboard.loading');

  const unsubscribe = authService.onAuthChange(async (firebaseUser) => {
    if (!firebaseUser) {
      window.location.href = '/login';
      return;
    }

    // Verificar rol de cliente
    const userDoc = await getDoc(doc(db, 'users', firebaseUser.uid));
    const userData = userDoc.data();
    if (!userData || userData.role !== 'client') {
      window.location.href = '/dashboard';
      return;
    }

    // Actualizar authStore
    setUser({
      uid: firebaseUser.uid,
      email: firebaseUser.email || '',
      name: userData.name || firebaseUser.displayName || 'Usuario',
      role: userData.role || 'client',
      hasActiveAlert: userData.hasActiveAlert ?? false,
      assignedTrainerId: userData.assignedTrainerId,
      medicalProfile: userData.medicalProfile,
    });

    loadingScreen.classList.add('hidden');
    dietsContent.classList.remove('hidden');

    subscribeToDiets(firebaseUser.uid, (diets) => {
      if (diets.length > 0 && diets[0]) {
        const d = diets[0];
        dietName.textContent = d.name;
        dietType.textContent = d.type + ' · ' + d.somatotype;
        dietCalories.textContent = `${d.totalCalories} kcal`;

        let sumCal = 0, sumP = 0, sumC = 0, sumF = 0;

        mealsList.innerHTML = '';
        if (d.meals && d.meals.length > 0) {
          d.meals.forEach((meal: any) => {
            sumCal += meal.calories || 0;
            sumP += meal.protein || 0;
            sumC += meal.carbs || 0;
            sumF += meal.fat || 0;

            const div = document.createElement('div');
            div.className = 'rounded-xl border border-zinc-800/40 bg-zinc-900/40 p-4 backdrop-blur-sm';
            div.innerHTML = `
              <div class="flex items-start justify-between">
                <div>
                  <h4 class="font-medium text-zinc-200 capitalize">${meal.name}</h4>
                  ${meal.description ? `<p class="mt-1 text-xs text-zinc-600">${meal.description}</p>` : ''}
                  <div class="mt-2 flex flex-wrap gap-3 text-xs text-zinc-500">
                    <span>Cal: ${meal.calories || 0}</span>
                    <span>P: ${meal.protein || 0}g</span>
                    <span>C: ${meal.carbs || 0}g</span>
                    <span>G: ${meal.fat || 0}g</span>
                  </div>
                </div>
              </div>
            `;
            mealsList.appendChild(div);
          });
        }

        totalCal.textContent = `${sumCal}`;
        totalProtein.textContent = `${sumP}`;
        totalCarbs.textContent = `${sumC}`;
        totalFat.textContent = `${sumF}`;

        dietCard.classList.remove('hidden');
        emptyState.classList.add('hidden');
      } else {
        dietCard.classList.add('hidden');
        emptyState.classList.remove('hidden');
      }
    });
  });

  // Cleanup on page unload
  document.addEventListener('astro:before-swap', () => {
    unsubscribe();
  });
</script>
