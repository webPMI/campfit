---
import ClientLayout from '@/layouts/ClientLayout.astro';
import { translations, type Language } from '@/i18n/translations';

const lang = (Astro.url.searchParams.get('lang') as Language) || 'es';
const t = (key: string) => translations[lang]?.[key] || translations['es']?.[key] || key;
---

<ClientLayout>
  <!-- Loading -->
  <div id="loadingScreen" class="flex min-h-screen items-center justify-center">
    <div class="text-center animate-fade-in">
      <div class="mx-auto h-10 w-10 animate-spin rounded-full border-4 border-zinc-700 border-t-emerald-400"></div>
      <p id="loadingText" class="mt-4 text-sm text-zinc-500">{t('dashboard.loading')}</p>
    </div>
  </div>

  <!-- Medical Profile Content -->
  <div id="medicalContent" class="hidden">
    <main class="mx-auto max-w-2xl px-4 py-6">
      <div class="animate-fade-in space-y-6">
        <!-- Header -->
        <div>
          <h2 class="text-xl font-bold">{t('client.medical.title')}</h2>
          <p class="mt-1 text-sm text-zinc-500">{t('client.medical.desc')}</p>
        </div>

        <!-- Success Message -->
        <div id="successMessage" class="hidden rounded-xl border border-emerald-500/30 bg-emerald-500/10 p-4 text-sm text-emerald-400">
          {t('client.medical.success')}
        </div>

        <!-- Error Message -->
        <div id="errorMessage" class="hidden rounded-xl border border-red-500/30 bg-red-500/10 p-4 text-sm text-red-400">
          {t('client.medical.error')}
        </div>

        <!-- Form -->
        <form id="medicalForm" class="space-y-6">
          <!-- Basic Info -->
          <div class="card-glow rounded-2xl border border-zinc-800/60 bg-zinc-900/80 p-6 backdrop-blur-xl">
            <h3 class="mb-4 text-sm font-semibold text-zinc-300 uppercase tracking-wider">Información básica</h3>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-zinc-400 mb-1.5">{t('client.medical.height')}</label>
                <input
                  id="heightInput"
                  type="number"
                  step="0.1"
                  placeholder="175"
                  class="w-full rounded-xl border border-zinc-700/50 bg-zinc-800/50 px-4 py-3 text-sm text-zinc-100 placeholder-zinc-600 outline-none transition-all focus:border-emerald-500/50 focus:ring-2 focus:ring-emerald-500/10"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-zinc-400 mb-1.5">{t('client.medical.weight')}</label>
                <input
                  id="weightInput"
                  type="number"
                  step="0.1"
                  placeholder="75"
                  class="w-full rounded-xl border border-zinc-700/50 bg-zinc-800/50 px-4 py-3 text-sm text-zinc-100 placeholder-zinc-600 outline-none transition-all focus:border-emerald-500/50 focus:ring-2 focus:ring-emerald-500/10"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-zinc-400 mb-1.5">{t('client.medical.age')}</label>
                <input
                  id="ageInput"
                  type="number"
                  placeholder="30"
                  class="w-full rounded-xl border border-zinc-700/50 bg-zinc-800/50 px-4 py-3 text-sm text-zinc-100 placeholder-zinc-600 outline-none transition-all focus:border-emerald-500/50 focus:ring-2 focus:ring-emerald-500/10"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-zinc-400 mb-1.5">{t('client.medical.gender')}</label>
                <select
                  id="genderSelect"
                  class="w-full rounded-xl border border-zinc-700/50 bg-zinc-800/50 px-4 py-3 text-sm text-zinc-100 outline-none transition-all focus:border-emerald-500/50 focus:ring-2 focus:ring-emerald-500/10"
                >
                  <option value="">Seleccionar</option>
                  <option value="male">{t('client.medical.gender.male')}</option>
                  <option value="female">{t('client.medical.gender.female')}</option>
                  <option value="other">{t('client.medical.gender.other')}</option>
                </select>
              </div>
            </div>
          </div>

          <!-- Medical Conditions -->
          <div class="card-glow rounded-2xl border border-zinc-800/60 bg-zinc-900/80 p-6 backdrop-blur-xl">
            <h3 class="mb-4 text-sm font-semibold text-zinc-300 uppercase tracking-wider">Historial médico</h3>
            <div class="space-y-4">
              <div>
                <label class="block text-sm font-medium text-zinc-400 mb-1.5">{t('client.medical.conditions')}</label>
                <textarea
                  id="conditionsInput"
                  rows="2"
                  placeholder="{t('client.medical.conditions.placeholder')}"
                  class="w-full rounded-xl border border-zinc-700/50 bg-zinc-800/50 px-4 py-3 text-sm text-zinc-100 placeholder-zinc-600 outline-none transition-all focus:border-emerald-500/50 focus:ring-2 focus:ring-emerald-500/10 resize-none"
                ></textarea>
              </div>
              <div>
                <label class="block text-sm font-medium text-zinc-400 mb-1.5">{t('client.medical.medications')}</label>
                <textarea
                  id="medicationsInput"
                  rows="2"
                  placeholder="{t('client.medical.medications.placeholder')}"
                  class="w-full rounded-xl border border-zinc-700/50 bg-zinc-800/50 px-4 py-3 text-sm text-zinc-100 placeholder-zinc-600 outline-none transition-all focus:border-emerald-500/50 focus:ring-2 focus:ring-emerald-500/10 resize-none"
                ></textarea>
              </div>
              <div>
                <label class="block text-sm font-medium text-zinc-400 mb-1.5">{t('client.medical.allergies')}</label>
                <textarea
                  id="allergiesInput"
                  rows="2"
                  placeholder="{t('client.medical.allergies.placeholder')}"
                  class="w-full rounded-xl border border-zinc-700/50 bg-zinc-800/50 px-4 py-3 text-sm text-zinc-100 placeholder-zinc-600 outline-none transition-all focus:border-emerald-500/50 focus:ring-2 focus:ring-emerald-500/10 resize-none"
                ></textarea>
              </div>
              <div>
                <label class="block text-sm font-medium text-zinc-400 mb-1.5">{t('client.medical.injuries')}</label>
                <textarea
                  id="injuriesInput"
                  rows="2"
                  placeholder="{t('client.medical.injuries.placeholder')}"
                  class="w-full rounded-xl border border-zinc-700/50 bg-zinc-800/50 px-4 py-3 text-sm text-zinc-100 placeholder-zinc-600 outline-none transition-all focus:border-emerald-500/50 focus:ring-2 focus:ring-emerald-500/10 resize-none"
                ></textarea>
              </div>
              <div>
                <label class="block text-sm font-medium text-zinc-400 mb-1.5">{t('client.medical.surgery')}</label>
                <textarea
                  id="surgeryInput"
                  rows="2"
                  placeholder="{t('client.medical.surgery.placeholder')}"
                  class="w-full rounded-xl border border-zinc-700/50 bg-zinc-800/50 px-4 py-3 text-sm text-zinc-100 placeholder-zinc-600 outline-none transition-all focus:border-emerald-500/50 focus:ring-2 focus:ring-emerald-500/10 resize-none"
                ></textarea>
              </div>
            </div>
          </div>

          <!-- Emergency Contact -->
          <div class="card-glow rounded-2xl border border-zinc-800/60 bg-zinc-900/80 p-6 backdrop-blur-xl">
            <h3 class="mb-4 text-sm font-semibold text-zinc-300 uppercase tracking-wider">Contacto de emergencia</h3>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-zinc-400 mb-1.5">{t('client.medical.emergency.name')}</label>
                <input
                  id="emergencyNameInput"
                  type="text"
                  placeholder="María García"
                  class="w-full rounded-xl border border-zinc-700/50 bg-zinc-800/50 px-4 py-3 text-sm text-zinc-100 placeholder-zinc-600 outline-none transition-all focus:border-emerald-500/50 focus:ring-2 focus:ring-emerald-500/10"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-zinc-400 mb-1.5">{t('client.medical.emergency.phone')}</label>
                <input
                  id="emergencyPhoneInput"
                  type="tel"
                  placeholder="+34 600 000 000"
                  class="w-full rounded-xl border border-zinc-700/50 bg-zinc-800/50 px-4 py-3 text-sm text-zinc-100 placeholder-zinc-600 outline-none transition-all focus:border-emerald-500/50 focus:ring-2 focus:ring-emerald-500/10"
                />
              </div>
            </div>
          </div>

          <!-- Submit -->
          <button
            id="saveBtn"
            type="submit"
            class="flex w-full items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-emerald-500 to-emerald-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-emerald-500/20 transition-all hover:from-emerald-400 hover:to-emerald-500 active:scale-[0.98]"
          >
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
            <span id="saveBtnText">{t('client.medical.save')}</span>
          </button>
        </form>
      </div>
    </main>
  </div>
</ClientLayout>

<script>
  import { authService } from '@/services/authService';
  import { setUser } from '@/stores/authStore';
  import { db } from '@/lib/firebase';
  import { doc, getDoc, updateDoc, serverTimestamp } from 'firebase/firestore';
  import { t } from '@/i18n/client';

  const loadingScreen = document.getElementById('loadingScreen')!;
  const loadingText = document.getElementById('loadingText')!;
  const medicalContent = document.getElementById('medicalContent')!;
  const medicalForm = document.getElementById('medicalForm') as HTMLFormElement;
  const saveBtn = document.getElementById('saveBtn') as HTMLButtonElement;
  const saveBtnText = document.getElementById('saveBtnText')!;
  const successMessage = document.getElementById('successMessage')!;
  const errorMessage = document.getElementById('errorMessage')!;

  const heightInput = document.getElementById('heightInput') as HTMLInputElement;
  const weightInput = document.getElementById('weightInput') as HTMLInputElement;
  const ageInput = document.getElementById('ageInput') as HTMLInputElement;
  const genderSelect = document.getElementById('genderSelect') as HTMLSelectElement;
  const conditionsInput = document.getElementById('conditionsInput') as HTMLTextAreaElement;
  const medicationsInput = document.getElementById('medicationsInput') as HTMLTextAreaElement;
  const allergiesInput = document.getElementById('allergiesInput') as HTMLTextAreaElement;
  const injuriesInput = document.getElementById('injuriesInput') as HTMLTextAreaElement;
  const surgeryInput = document.getElementById('surgeryInput') as HTMLTextAreaElement;
  const emergencyNameInput = document.getElementById('emergencyNameInput') as HTMLInputElement;
  const emergencyPhoneInput = document.getElementById('emergencyPhoneInput') as HTMLInputElement;

  loadingText.textContent = t('dashboard.loading');

  const unsubscribe = authService.onAuthChange(async (firebaseUser) => {
    if (!firebaseUser) {
      window.location.href = '/login';
      return;
    }

    // Verificar rol de cliente
    const userDoc = await getDoc(doc(db, 'users', firebaseUser.uid));
    const userData = userDoc.data();
    if (!userData || userData.role !== 'client') {
      window.location.href = '/dashboard';
      return;
    }

    // Actualizar authStore
    setUser({
      uid: firebaseUser.uid,
      email: firebaseUser.email || '',
      name: userData.name || firebaseUser.displayName || 'Usuario',
      role: userData.role || 'client',
      hasActiveAlert: userData.hasActiveAlert ?? false,
      assignedTrainerId: userData.assignedTrainerId,
      medicalProfile: userData.medicalProfile,
    });

    // Cargar datos existentes si los hay
    const mp = userData.medicalProfile;
    if (mp) {
      if (mp.height) heightInput.value = mp.height;
      if (mp.weight) weightInput.value = mp.weight;
      if (mp.age) ageInput.value = mp.age;
      if (mp.gender) genderSelect.value = mp.gender;
      if (mp.conditions) conditionsInput.value = mp.conditions;
      if (mp.medications) medicationsInput.value = mp.medications;
      if (mp.allergies) allergiesInput.value = mp.allergies;
      if (mp.injuries) injuriesInput.value = mp.injuries;
      if (mp.surgery) surgeryInput.value = mp.surgery;
      if (mp.emergencyName) emergencyNameInput.value = mp.emergencyName;
      if (mp.emergencyPhone) emergencyPhoneInput.value = mp.emergencyPhone;
    }

    loadingScreen.classList.add('hidden');
    medicalContent.classList.remove('hidden');
  });

  // Guardar perfil médico
  medicalForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    successMessage.classList.add('hidden');
    errorMessage.classList.add('hidden');

    saveBtn.disabled = true;
    saveBtnText.textContent = t('client.medical.saving');

    try {
      authService.onAuthChange(() => {});
      // No podemos obtener el uid fácilmente aquí, usamos el store
      // En su lugar, obtenemos el usuario actual del auth
      const { auth } = await import('@/lib/firebase');
      const currentUser = auth.currentUser;
      if (!currentUser) {
        window.location.href = '/login';
        return;
      }

      const medicalProfile = {
        height: heightInput.value ? parseFloat(heightInput.value) : null,
        weight: weightInput.value ? parseFloat(weightInput.value) : null,
        age: ageInput.value ? parseInt(ageInput.value) : null,
        gender: genderSelect.value || null,
        conditions: conditionsInput.value || '',
        medications: medicationsInput.value || '',
        allergies: allergiesInput.value || '',
        injuries: injuriesInput.value || '',
        surgery: surgeryInput.value || '',
        emergencyName: emergencyNameInput.value || '',
        emergencyPhone: emergencyPhoneInput.value || '',
        updatedAt: serverTimestamp(),
      };

      await updateDoc(doc(db, 'users', currentUser.uid), {
        medicalProfile,
        updatedAt: serverTimestamp(),
      });

      successMessage.classList.remove('hidden');
      setTimeout(() => successMessage.classList.add('hidden'), 5000);
    } catch (err) {
      console.error('Error saving medical profile:', err);
      errorMessage.classList.remove('hidden');
      setTimeout(() => errorMessage.classList.add('hidden'), 5000);
    } finally {
      saveBtn.disabled = false;
      saveBtnText.textContent = t('client.medical.save');
    }
  });

  // Cleanup on page unload
  document.addEventListener('astro:before-swap', () => {
    unsubscribe();
  });
</script>
