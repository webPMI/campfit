---
import ClientLayout from '@/layouts/ClientLayout.astro';
import { translations, type Language } from '@/i18n/translations';

const lang = (Astro.url.searchParams.get('lang') as Language) || 'es';
const t = (key: string) => translations[lang]?.[key] || translations['es']?.[key] || key;
---

<ClientLayout>
  <div id="loadingScreen" class="flex min-h-screen items-center justify-center">
    <div class="text-center animate-fade-in">
      <div class="mx-auto h-10 w-10 animate-spin rounded-full border-4 border-zinc-700 border-t-emerald-400"></div>
      <p id="loadingText" class="mt-4 text-sm text-zinc-500">{t('dashboard.loading')}</p>
    </div>
  </div>

  <div id="workoutsContent" class="hidden">
    <main class="mx-auto max-w-4xl px-4 py-6">
      <div class="animate-fade-in space-y-6">
        <!-- Header -->
        <div>
          <h2 class="text-xl font-bold">{t('dashboard.routines')}</h2>
          <p class="mt-1 text-sm text-zinc-500">{t('dashboard.routines.desc')}</p>
        </div>

        <!-- Workout Card -->
        <div id="workoutCard" class="hidden card-glow rounded-2xl border border-zinc-800/60 bg-zinc-900/80 p-6 backdrop-blur-xl">
          <div class="flex items-center justify-between mb-4">
            <div>
              <h3 id="workoutName" class="text-lg font-bold text-zinc-100"></h3>
              <span id="workoutDifficulty" class="mt-1 inline-block rounded-full bg-emerald-500/10 px-3 py-1 text-xs font-medium text-emerald-400"></span>
            </div>
            <p id="workoutDescription" class="text-sm text-zinc-500 max-w-xs text-right"></p>
          </div>

          <div class="space-y-3" id="exercisesList">
            <!-- Exercises rendered by JS -->
          </div>

          <button
            id="completeWorkoutBtn"
            class="mt-6 flex w-full items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-emerald-500 to-emerald-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-emerald-500/20 transition-all hover:from-emerald-400 hover:to-emerald-500 active:scale-[0.98]"
          >
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
            Marcar rutina completada
          </button>
        </div>

        <!-- Empty State -->
        <div id="emptyState" class="flex flex-col items-center justify-center rounded-2xl border border-dashed border-zinc-800/60 bg-zinc-900/40 p-12 text-center">
          <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-zinc-800/50">
            <svg class="h-8 w-8 text-zinc-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 0 1-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 0 0 6.16-12.12A14.98 14.98 0 0 0 9.631 8.41m5.96 5.96a14.926 14.926 0 0 1-5.841 2.58m-.119-8.54a6 6 0 0 0-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 0 0-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 0 1-2.448-2.448 14.9 14.9 0 0 1 .06-.312m-2.24 2.39a4.493 4.493 0 0 0-1.757 4.306 4.493 4.493 0 0 0 4.306-1.758M16.5 9a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0Z" />
            </svg>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-zinc-400">{t('client.no.workout')}</h3>
          <p class="mt-2 text-sm text-zinc-600">Tu entrenador asignará una rutina personalizada para ti.</p>
        </div>
      </div>
    </main>
  </div>
</ClientLayout>

<script>
  import { authService } from '@/services/authService';
  import { setUser } from '@/stores/authStore';
  import { db } from '@/lib/firebase';
  import { doc, getDoc } from 'firebase/firestore';
  import { subscribeToWorkouts } from '@/lib/client/workoutService';
  import { t } from '@/i18n/client';

  const loadingScreen = document.getElementById('loadingScreen')!;
  const loadingText = document.getElementById('loadingText')!;
  const workoutsContent = document.getElementById('workoutsContent')!;
  const workoutCard = document.getElementById('workoutCard')!;
  const emptyState = document.getElementById('emptyState')!;
  const workoutName = document.getElementById('workoutName')!;
  const workoutDifficulty = document.getElementById('workoutDifficulty')!;
  const workoutDescription = document.getElementById('workoutDescription')!;
  const exercisesList = document.getElementById('exercisesList')!;
  // const completeWorkoutBtn = document.getElementById('completeWorkoutBtn')!;

  loadingText.textContent = t('dashboard.loading');

  const unsubscribe = authService.onAuthChange(async (firebaseUser) => {
    if (!firebaseUser) {
      window.location.href = '/login';
      return;
    }

    // Verificar rol de cliente
    const userDoc = await getDoc(doc(db, 'users', firebaseUser.uid));
    const userData = userDoc.data();
    if (!userData || userData.role !== 'client') {
      window.location.href = '/dashboard';
      return;
    }

    // Actualizar authStore
    setUser({
      uid: firebaseUser.uid,
      email: firebaseUser.email || '',
      name: userData.name || firebaseUser.displayName || 'Usuario',
      role: userData.role || 'client',
      hasActiveAlert: userData.hasActiveAlert ?? false,
      assignedTrainerId: userData.assignedTrainerId,
      medicalProfile: userData.medicalProfile,
    });

    loadingScreen.classList.add('hidden');
    workoutsContent.classList.remove('hidden');

    subscribeToWorkouts(firebaseUser.uid, (workouts) => {
      if (workouts.length > 0 && workouts[0]) {
        const w = workouts[0];
        workoutName.textContent = w.name;
        workoutDifficulty.textContent = w.difficulty;
        workoutDescription.textContent = w.description;

        exercisesList.innerHTML = '';
        if (w.exercises && w.exercises.length > 0) {
          w.exercises.forEach((ex: any, i: number) => {
            const div = document.createElement('div');
            div.className = 'rounded-xl border border-zinc-800/40 bg-zinc-900/40 p-4 backdrop-blur-sm';
            div.innerHTML = `
              <div class="flex items-start justify-between">
                <div class="flex-1">
                  <div class="flex items-center gap-2">
                    <span class="flex h-6 w-6 items-center justify-center rounded-full bg-emerald-500/10 text-xs font-bold text-emerald-400">${i + 1}</span>
                    <h4 class="font-medium text-zinc-200">${ex.name}</h4>
                  </div>
                  <div class="mt-2 flex flex-wrap gap-3 text-xs text-zinc-500">
                    <span>${ex.sets} series × ${ex.reps} reps</span>
                    <span>Descanso: ${ex.restTime || '90s'}</span>
                  </div>
                  ${ex.description ? `<p class="mt-2 text-xs text-zinc-600">${ex.description}</p>` : ''}
                </div>
              </div>
            `;
            exercisesList.appendChild(div);
          });
        }

        workoutCard.classList.remove('hidden');
        emptyState.classList.add('hidden');
      } else {
        workoutCard.classList.add('hidden');
        emptyState.classList.remove('hidden');
      }
    });
  });

  // Cleanup on page unload
  document.addEventListener('astro:before-swap', () => {
    unsubscribe();
  });
</script>
