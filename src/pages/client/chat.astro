---
import ClientLayout from '@/layouts/ClientLayout.astro';
import { translations, type Language } from '@/i18n/translations';

const lang = (Astro.url.searchParams.get('lang') as Language) || 'es';
const t = (key: string) => translations[lang]?.[key] || translations['es']?.[key] || key;
---

<ClientLayout>
  <div id="loadingScreen" class="flex min-h-screen items-center justify-center">
    <div class="text-center animate-fade-in">
      <div class="mx-auto h-10 w-10 animate-spin rounded-full border-4 border-zinc-700 border-t-emerald-400"></div>
      <p id="loadingText" class="mt-4 text-sm text-zinc-500">{t('dashboard.loading')}</p>
    </div>
  </div>

  <div id="chatContent" class="hidden flex flex-col" style="height: calc(100vh - 8rem);">
    <!-- Chat Header -->
    <header class="border-b border-zinc-800/60 bg-zinc-900/50 backdrop-blur-xl px-4 py-3">
      <div class="flex items-center gap-3">
        <div class="flex h-9 w-9 items-center justify-center rounded-full bg-gradient-to-br from-emerald-400 to-emerald-600">
          <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
          </svg>
        </div>
        <div>
          <h2 class="text-sm font-semibold text-zinc-200">Chat con tu entrenador</h2>
          <p class="text-xs text-zinc-500">Disponible en horario de atencion</p>
        </div>
      </div>
    </header>

    <!-- Messages -->
    <div id="messagesContainer" class="flex-1 overflow-y-auto px-4 py-4 space-y-3">
      <div class="flex justify-center">
        <p class="text-xs text-zinc-600">Cargando mensajes...</p>
      </div>
    </div>

    <!-- Input -->
    <div class="border-t border-zinc-800/60 bg-zinc-900/80 backdrop-blur-xl px-4 py-3">
      <div class="flex gap-3">
        <input
          id="chatInput"
          type="text"
          placeholder="Escribe un mensaje..."
          class="flex-1 rounded-xl border border-zinc-700/50 bg-zinc-800/50 px-4 py-3 text-sm text-zinc-100 placeholder-zinc-600 outline-none transition-all focus:border-emerald-500/50 focus:ring-2 focus:ring-emerald-500/10"
        />
        <button
          id="sendBtn"
          class="flex items-center justify-center rounded-xl bg-gradient-to-r from-emerald-500 to-emerald-600 px-4 py-3 text-white shadow-lg shadow-emerald-500/20 transition-all hover:from-emerald-400 hover:to-emerald-500 active:scale-[0.98]"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</ClientLayout>

<script>
  import { authService } from '@/services/authService';
  import { setUser } from '@/stores/authStore';
  import { db } from '@/lib/firebase';
  import { doc, getDoc } from 'firebase/firestore';
  import { collection, query, where, orderBy, onSnapshot, addDoc, serverTimestamp } from 'firebase/firestore';
  import { t } from '@/i18n/client';

  const loadingScreen = document.getElementById('loadingScreen')!;
  const loadingText = document.getElementById('loadingText')!;
  const chatContent = document.getElementById('chatContent')!;
  const messagesContainer = document.getElementById('messagesContainer')!;
  const chatInput = document.getElementById('chatInput') as HTMLInputElement;
  const sendBtn = document.getElementById('sendBtn') as HTMLButtonElement;

  loadingText.textContent = t('dashboard.loading');

  const unsubscribe = authService.onAuthChange(async (firebaseUser) => {
    if (!firebaseUser) {
      window.location.href = '/login';
      return;
    }

    // Verificar rol de cliente
    const userDoc = await getDoc(doc(db, 'users', firebaseUser.uid));
    const userData = userDoc.data();
    if (!userData || userData.role !== 'client') {
      window.location.href = '/dashboard';
      return;
    }

    // Actualizar authStore
    setUser({
      uid: firebaseUser.uid,
      email: firebaseUser.email || '',
      name: userData.name || firebaseUser.displayName || 'Usuario',
      role: userData.role || 'client',
      hasActiveAlert: userData.hasActiveAlert ?? false,
      assignedTrainerId: userData.assignedTrainerId,
      medicalProfile: userData.medicalProfile,
    });

    loadingScreen.classList.add('hidden');
    chatContent.classList.remove('hidden');

    const chatQuery = query(
      collection(db, 'messages'),
      where('participants', 'array-contains', firebaseUser.uid),
      orderBy('createdAt', 'asc')
    );

    onSnapshot(chatQuery, (snapshot) => {
      messagesContainer.innerHTML = '';
      if (snapshot.empty) {
        messagesContainer.innerHTML =
          '<div class="flex justify-center pt-8"><p class="text-sm text-zinc-600">No hay mensajes aun. Envia un saludo a tu entrenador!</p></div>';
        return;
      }

      snapshot.docs.forEach((doc) => {
        const msg = doc.data();
        const isMine = msg.senderId === firebaseUser.uid;
        const time = msg.createdAt && msg.createdAt.toDate
          ? msg.createdAt.toDate().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })
          : '';

        const div = document.createElement('div');
        div.className = 'flex ' + (isMine ? 'justify-end' : 'justify-start');

        const bubbleClass = isMine
          ? 'bg-gradient-to-r from-emerald-500 to-emerald-600 text-white rounded-br-md'
          : 'bg-zinc-800/80 text-zinc-200 rounded-bl-md';

        const timeClass = isMine ? 'text-right' : 'text-left';

        div.innerHTML =
          '<div class="max-w-[80%]">' +
            '<div class="rounded-2xl px-4 py-2.5 text-sm leading-relaxed ' + bubbleClass + '">' +
              msg.content +
            '</div>' +
            '<p class="mt-1 text-[10px] text-zinc-600 ' + timeClass + '">' + time + '</p>' +
          '</div>';

        messagesContainer.appendChild(div);
      });

      messagesContainer.scrollTop = messagesContainer.scrollHeight;
    });

    async function handleSend() {
      const content = chatInput.value.trim();
      if (!content) return;

      chatInput.disabled = true;
      sendBtn.disabled = true;

      try {
        const trainerId = userData?.assignedTrainerId || 'admin';

        await addDoc(collection(db, 'messages'), {
          senderId: firebaseUser!.uid,
          receiverId: trainerId,
          participants: [firebaseUser!.uid, trainerId],
          content: content,
          type: 'text',
          isRead: false,
          createdAt: serverTimestamp(),
        });

        chatInput.value = '';
      } catch (err) {
        console.error('Error sending message:', err);
      } finally {
        chatInput.disabled = false;
        sendBtn.disabled = false;
        chatInput.focus();
      }
    }

    sendBtn.addEventListener('click', handleSend);
    chatInput.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        handleSend();
      }
    });
  });

  // Cleanup on page unload
  document.addEventListener('astro:before-swap', () => {
    unsubscribe();
  });
</script>
