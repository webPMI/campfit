---
import TrainerLayout from '@/layouts/TrainerLayout.astro';
import { translations, type Language } from '@/i18n/translations';

const lang = (Astro.url.searchParams.get('lang') as Language) || 'es';
const t = (key: string) => translations[lang]?.[key] || translations['es']?.[key] || key;
---

<TrainerLayout>
  <div class="mx-auto max-w-4xl px-4 py-8">
    <div class="animate-fade-in">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-bold">{t('trainer.workouts')}</h1>
          <p class="mt-1 text-sm text-zinc-500">
            <span id="workout-count" class="text-blue-400 font-medium">0</span> {t('admin.workouts.total')}
          </p>
        </div>
        <button id="btn-create-workout" class="rounded-xl bg-emerald-500/10 border border-emerald-500/20 px-4 py-2 text-sm font-medium text-emerald-400 hover:bg-emerald-500/20 transition-all active:scale-95">
          <svg class="h-4 w-4 inline-block mr-1 -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
          {t('trainer.workouts.new')}
        </button>
      </div>

      <!-- Workout Editor -->
      <div id="workout-editor" class="hidden mt-8"></div>

      <!-- Filter by client -->
      <div class="mt-6">
        <select id="client-filter" class="w-full rounded-xl border border-zinc-800/40 bg-zinc-900/60 px-4 py-2.5 text-sm text-zinc-300 backdrop-blur-sm focus:outline-none focus:border-emerald-500/50">
          <option value="">{t('trainer.filter.all')}</option>
        </select>
      </div>

      <!-- Workouts List -->
      <div id="workouts-container" class="mt-6 space-y-3">
        <div class="rounded-xl border border-zinc-800/40 bg-zinc-900/40 p-6 text-center backdrop-blur-sm">
          <div class="flex items-center justify-center gap-3">
            <svg class="h-5 w-5 animate-spin text-emerald-400" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z" />
            </svg>
            <p class="text-sm text-zinc-500">{t('admin.loading')}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</TrainerLayout>

<script>
  import { requireAuth } from '@/lib/shared/authGuard';
  import { ICONS, escapeHtml, renderEmptyState } from '@/lib/shared/ui';
  import {
    subscribeToClients,
    subscribeToWorkoutsByTrainer,
    createWorkout,
    updateWorkout,
    deleteWorkout,
  } from '@/lib/trainer/trainerUtils';
  import type { TrainerClient, TrainerWorkout, Exercise } from '@/lib/trainer/trainerUtils';

  let unsubClients: (() => void) | null = null;
  let unsubWorkouts: (() => void) | null = null;
  let allClients: TrainerClient[] = [];
  let allWorkouts: TrainerWorkout[] = [];

  requireAuth(async (user) => {
    initWorkouts(user.uid);
  });

  window.addEventListener('beforeunload', () => {
    unsubClients?.();
    unsubWorkouts?.();
  });

  async function initWorkouts(trainerId: string): Promise<void> {
    const container = document.getElementById('workouts-container')!;
    const editor = document.getElementById('workout-editor')!;
    const btnCreate = document.getElementById('btn-create-workout')!;
    const clientFilter = document.getElementById('client-filter') as HTMLSelectElement;
    const workoutCount = document.getElementById('workout-count')!;

    // Subscribe to clients for filter
    unsubClients = subscribeToClients(trainerId, (clients) => {
      allClients = clients;
      clientFilter.innerHTML = `<option value="">${escapeHtml('Todos los clientes')}</option>` +
        clients.map((c) => `<option value="${c.uid}">${escapeHtml(c.name)}</option>`).join('');

      const urlClientId = new URLSearchParams(window.location.search).get('clientId');
      if (urlClientId) clientFilter.value = urlClientId;
    });

    // Subscribe to workouts
    unsubWorkouts = subscribeToWorkoutsByTrainer(trainerId, (workouts) => {
      allWorkouts = workouts;
      workoutCount.textContent = String(workouts.length);
      applyFilters();
    });

    clientFilter.addEventListener('change', () => applyFilters());

    btnCreate.addEventListener('click', () => {
      const urlClientId = clientFilter.value || '';
      showEditor(null, trainerId, urlClientId);
    });

    (window as any).__editWorkout = (id: string) => {
      const workout = allWorkouts.find((w) => w.id === id);
      if (workout) showEditor(workout, trainerId);
    };

    (window as any).__deleteWorkoutConfirm = async (id: string) => {
      showDeleteConfirm(id);
    };
  }

  function showDeleteConfirm(id: string): void {
    const existing = document.getElementById('confirm-modal');
    if (existing) existing.remove();

    const modal = document.createElement('div');
    modal.id = 'confirm-modal';
    modal.className = 'fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm';
    modal.innerHTML = `
      <div class="mx-4 w-full max-w-sm rounded-2xl border border-zinc-700/50 bg-zinc-900/95 p-6 shadow-2xl backdrop-blur-xl">
        <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-red-500/10 mx-auto">
          <svg class="h-6 w-6 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
          </svg>
        </div>
        <h3 class="text-center text-lg font-semibold text-zinc-200">Eliminar rutina</h3>
        <p class="mt-2 text-center text-sm text-zinc-500">¿Estás seguro? Esta acción no se puede deshacer.</p>
        <div class="mt-6 flex gap-3">
          <button id="btn-cancel-delete" class="flex-1 rounded-xl border border-zinc-700/50 bg-zinc-800/80 px-4 py-2.5 text-sm font-medium text-zinc-300 hover:bg-zinc-700/80 transition-all">Cancelar</button>
          <button id="btn-confirm-delete" class="flex-1 rounded-xl bg-red-500/10 border border-red-500/20 px-4 py-2.5 text-sm font-medium text-red-400 hover:bg-red-500/20 transition-all">Eliminar</button>
        </div>
      </div>
    `;
    document.body.appendChild(modal);

    document.getElementById('btn-cancel-delete')!.addEventListener('click', () => modal.remove());
    document.getElementById('btn-confirm-delete')!.addEventListener('click', async () => {
      modal.remove();
      await deleteWorkout(id);
    });
    modal.addEventListener('click', (e) => { if (e.target === modal) modal.remove(); });
  }

  function applyFilters(): void {
    const container = document.getElementById('workouts-container')!;
    const clientFilter = document.getElementById('client-filter') as HTMLSelectElement;
    const clientId = clientFilter.value;

    let filtered = allWorkouts;
    if (clientId) filtered = filtered.filter((w) => w.clientId === clientId);

    if (filtered.length === 0) {
      container.innerHTML = renderEmptyState(
        ICONS.workouts,
        clientId ? 'Este cliente no tiene rutinas' : 'No has creado rutinas aún',
      );
      return;
    }

    container.innerHTML = filtered
      .map((w) => {
        const clientName = allClients.find((c) => c.uid === w.clientId)?.name || 'Sin cliente';
        const difficultyLabels: Record<string, string> = { easy: 'Fácil', medium: 'Intermedio', hard: 'Avanzado', custom: 'Personalizado' };
        return `
          <div class="rounded-xl border border-zinc-800/40 bg-zinc-900/40 p-4 backdrop-blur-sm transition-all hover:border-zinc-700/60">
            <div class="flex items-center justify-between">
              <div class="min-w-0 flex-1">
                <p class="text-sm font-medium text-zinc-200">${escapeHtml(w.name)}</p>
                <p class="text-xs text-zinc-500 mt-0.5">
                  <span class="text-emerald-400">${escapeHtml(clientName)}</span>
                  <span class="text-zinc-600 mx-1">·</span>
                  ${w.exercises?.length || 0} ejercicios
                  <span class="text-zinc-600 mx-1">·</span>
                  ${difficultyLabels[w.difficulty] || w.difficulty}
                </p>
              </div>
              <div class="flex items-center gap-2 shrink-0 ml-4">
                <span class="rounded-full bg-blue-500/10 px-2.5 py-0.5 text-xs font-medium text-blue-400 border border-blue-500/20">${w.exercises?.length || 0}</span>
                <button onclick="window.__editWorkout('${w.id}')" class="rounded-lg border border-zinc-700/50 bg-zinc-800/80 px-2.5 py-1.5 text-xs text-zinc-400 hover:text-zinc-200 transition-all">
                  <svg class="h-3.5 w-3.5 inline-block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                  </svg>
                </button>
                <button onclick="window.__deleteWorkoutConfirm('${w.id}')" class="rounded-lg border border-red-900/30 bg-red-500/10 px-2.5 py-1.5 text-xs text-red-400 hover:bg-red-500/20 transition-all">
                  <svg class="h-3.5 w-3.5 inline-block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                  </svg>
                </button>
              </div>
            </div>
          </div>
        `;
      })
      .join('');
  }

  function showEditor(workout: TrainerWorkout | null, trainerId: string, preselectedClientId?: string): void {
    const editor = document.getElementById('workout-editor')!;
    const isEditing = !!workout;
    editor.classList.remove('hidden');
    editor.scrollIntoView({ behavior: 'smooth', block: 'start' });

    const w = workout || {
      id: '',
      clientId: preselectedClientId || '',
      trainerId,
      name: '',
      difficulty: 'medium',
      description: '',
      exercises: [] as Exercise[],
    };

    const clientOptions = allClients
      .map((c) => `<option value="${c.uid}" ${c.uid === w.clientId ? 'selected' : ''}>${escapeHtml(c.name)}</option>`)
      .join('');

    const dayOptions = ['Lunes', 'Martes', 'Miércoles', 'Jueves', 'Viernes', 'Sábado', 'Domingo']
      .map((day, i) => `<option value="${i + 1}">${day}</option>`).join('');

    editor.innerHTML = `
      <div class="rounded-xl border border-zinc-800/40 bg-zinc-900/60 p-5 backdrop-blur-sm">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold text-zinc-200">${isEditing ? 'Editar Rutina' : 'Nueva Rutina'}</h2>
          <button onclick="window.__closeEditor()" class="rounded-lg border border-zinc-700/50 bg-zinc-800/80 px-3 py-1.5 text-xs text-zinc-400 hover:text-zinc-200 transition-all">Cancelar</button>
        </div>

        <div class="space-y-4">
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            <div>
              <label class="block text-xs text-zinc-500 mb-1">Nombre de la rutina</label>
              <input id="workout-name" type="text" value="${escapeHtml(w.name)}" placeholder="Ej: Full Body A" class="w-full rounded-xl border border-zinc-800/40 bg-zinc-900/40 px-4 py-2.5 text-sm text-zinc-200 placeholder-zinc-600 focus:outline-none focus:border-emerald-500/50" />
              <p id="workout-name-error" class="mt-1 hidden text-xs text-red-400">El nombre es obligatorio</p>
            </div>
            <div>
              <label class="block text-xs text-zinc-500 mb-1">Cliente</label>
              <select id="workout-client" class="w-full rounded-xl border border-zinc-800/40 bg-zinc-900/40 px-4 py-2.5 text-sm text-zinc-300 focus:outline-none focus:border-emerald-500/50">
                <option value="">Seleccionar cliente</option>
                ${clientOptions}
              </select>
              <p id="workout-client-error" class="mt-1 hidden text-xs text-red-400">Debes seleccionar un cliente</p>
            </div>
          </div>

          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            <div>
              <label class="block text-xs text-zinc-500 mb-1">Dificultad</label>
              <select id="workout-difficulty" class="w-full rounded-xl border border-zinc-800/40 bg-zinc-900/40 px-4 py-2.5 text-sm text-zinc-300 focus:outline-none focus:border-emerald-500/50">
                <option value="easy" ${w.difficulty === 'easy' ? 'selected' : ''}>Fácil</option>
                <option value="medium" ${w.difficulty === 'medium' ? 'selected' : ''}>Intermedio</option>
                <option value="hard" ${w.difficulty === 'hard' ? 'selected' : ''}>Avanzado</option>
                <option value="custom" ${w.difficulty === 'custom' ? 'selected' : ''}>Personalizado</option>
              </select>
            </div>
            <div>
              <label class="block text-xs text-zinc-500 mb-1">Día de la semana (por defecto)</label>
              <select id="workout-default-day" class="w-full rounded-xl border border-zinc-800/40 bg-zinc-900/40 px-4 py-2.5 text-sm text-zinc-300 focus:outline-none focus:border-emerald-500/50">
                ${dayOptions}
              </select>
            </div>
          </div>

          <div>
            <label class="block text-xs text-zinc-500 mb-1">Descripción</label>
            <textarea id="workout-desc" rows="2" placeholder="Descripción de la rutina..." class="w-full rounded-xl border border-zinc-800/40 bg-zinc-900/40 px-4 py-2.5 text-sm text-zinc-200 placeholder-zinc-600 focus:outline-none focus:border-emerald-500/50">${escapeHtml(w.description || '')}</textarea>
          </div>

          <!-- Exercises -->
          <div>
            <div class="flex items-center justify-between mb-2">
              <label class="text-xs text-zinc-500">Ejercicios <span id="exercise-count-badge" class="text-zinc-600">(${w.exercises.length})</span></label>
              <button id="btn-add-exercise" class="text-xs text-emerald-400 hover:text-emerald-300 transition-colors">
                <svg class="h-3.5 w-3.5 inline-block mr-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                </svg>
                Agregar ejercicio
              </button>
            </div>
            <div id="exercises-list" class="space-y-2">
              ${w.exercises.length === 0
                ? '<p class="text-xs text-zinc-600 py-2">No hay ejercicios agregados</p>'
                : w.exercises.map((ex, i) => renderExerciseRow(ex, i, dayOptions)).join('')
              }
            </div>
          </div>

          <button id="btn-save-workout" class="w-full rounded-xl bg-emerald-500/10 border border-emerald-500/20 px-4 py-3 text-sm font-medium text-emerald-400 hover:bg-emerald-500/20 transition-all active:scale-[0.99] disabled:opacity-50 disabled:cursor-not-allowed">
            <span id="save-btn-text">${isEditing ? 'Guardar Cambios' : 'Crear Rutina'}</span>
            <span id="save-btn-spinner" class="hidden">
              <svg class="h-4 w-4 animate-spin inline-block" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z" />
              </svg>
              Guardando...
            </span>
          </button>
        </div>
      </div>
    `;

    let exerciseCounter = w.exercises.length;
    const exercisesList = document.getElementById('exercises-list')!;
    const exerciseCountBadge = document.getElementById('exercise-count-badge')!;

    function updateExerciseCount(): void {
      const count = exercisesList.querySelectorAll('[data-exercise-row]').length;
      exerciseCountBadge.textContent = `(${count})`;
    }

    document.getElementById('btn-add-exercise')!.addEventListener('click', () => {
      exerciseCounter++;
      const newEx: Exercise = {
        id: `ex-${Date.now()}`,
        name: '',
        sets: 3,
        reps: 10,
        restTime: '60s',
        videoUrl: '',
        description: '',
        order: exerciseCounter,
        dayOfWeek: 1,
      };
      const wrapper = document.createElement('div');
      wrapper.innerHTML = renderExerciseRow(newEx, exerciseCounter - 1, dayOptions);
      const firstChild = exercisesList.firstChild;
      if (firstChild && exercisesList.children.length === 1 && exercisesList.querySelector('p.text-zinc-600')) {
        exercisesList.innerHTML = '';
      }
      exercisesList.appendChild(wrapper.firstElementChild || wrapper);
      updateExerciseCount();
    });

    exercisesList.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.closest('[data-remove-exercise]')) {
        const row = target.closest('[data-exercise-row]');
        if (row) {
          row.remove();
          updateExerciseCount();
        }
      }
    });

    document.getElementById('btn-save-workout')!.addEventListener('click', async () => {
      const name = (document.getElementById('workout-name') as HTMLInputElement).value.trim();
      const clientId = (document.getElementById('workout-client') as HTMLSelectElement).value;
      const difficulty = (document.getElementById('workout-difficulty') as HTMLSelectElement).value;
      const description = (document.getElementById('workout-desc') as HTMLTextAreaElement).value.trim();
      const nameError = document.getElementById('workout-name-error')!;
      const clientError = document.getElementById('workout-client-error')!;
      const btnSave = document.getElementById('btn-save-workout') as HTMLButtonElement;
      const btnText = document.getElementById('save-btn-text')!;
      const btnSpinner = document.getElementById('save-btn-spinner')!;

      let hasError = false;
      if (!name) { nameError.classList.remove('hidden'); hasError = true; } else { nameError.classList.add('hidden'); }
      if (!clientId) { clientError.classList.remove('hidden'); hasError = true; } else { clientError.classList.add('hidden'); }
      if (hasError) return;

      btnSave.disabled = true;
      btnText.classList.add('hidden');
      btnSpinner.classList.remove('hidden');

      const exerciseElements = exercisesList.querySelectorAll('[data-exercise-row]');
      const exercises: Exercise[] = Array.from(exerciseElements).map((el, idx) => {
        const inputs = el.querySelectorAll('input, select');
        return {
          id: `ex-${Date.now()}-${idx}`,
          name: (inputs[0] as HTMLInputElement).value,
          sets: parseInt((inputs[1] as HTMLInputElement).value) || 3,
          reps: parseInt((inputs[2] as HTMLInputElement).value) || 10,
          restTime: (inputs[3] as HTMLInputElement).value || '60s',
          videoUrl: '',
          description: (inputs[4] as HTMLInputElement)?.value || '',
          order: idx + 1,
          dayOfWeek: parseInt((inputs[5] as HTMLSelectElement)?.value) || 1,
        };
      }).filter((ex) => ex.name.trim() !== '');

      try {
        if (isEditing && workout) {
          await updateWorkout(workout.id, { name, clientId, trainerId, difficulty, description, exercises });
        } else {
          await createWorkout({ clientId, trainerId, name, difficulty, description, exercises });
        }
        editor.classList.add('hidden');
        editor.innerHTML = '';
      } catch (error) {
        console.error('[TrainerWorkouts] Error saving:', error);
      } finally {
        btnSave.disabled = false;
        btnText.classList.remove('hidden');
        btnSpinner.classList.add('hidden');
      }
    });

    // Close editor via event delegation (data-action="close-editor")
  }

  function renderExerciseRow(exercise: Exercise, index: number, dayOptions: string): string {
    return `
      <div data-exercise-row class="rounded-xl border border-zinc-800/40 bg-zinc-900/40 p-3 backdrop-blur-sm">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-xs text-zinc-600 font-medium w-5">#${index + 1}</span>
          <input type="text" value="${escapeHtml(exercise.name)}" placeholder="Nombre del ejercicio" class="flex-1 min-w-0 rounded-lg border border-zinc-800/40 bg-zinc-800/60 px-2.5 py-1.5 text-xs text-zinc-200 placeholder-zinc-600 focus:outline-none focus:border-emerald-500/50" />
          <select class="w-24 rounded-lg border border-zinc-800/40 bg-zinc-800/60 px-2 py-1.5 text-xs text-zinc-300 focus:outline-none focus:border-emerald-500/50">
            ${dayOptions}
          </select>
          <button data-remove-exercise class="rounded-lg border border-red-900/30 bg-red-500/10 px-2 py-1.5 text-xs text-red-400 hover:bg-red-500/20 transition-all">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        <div class="flex items-center gap-2">
          <div class="flex items-center gap-1.5">
            <label class="text-[10px] text-zinc-600">Series</label>
            <input type="number" value="${exercise.sets}" min="1" max="20" class="w-14 rounded-lg border border-zinc-800/40 bg-zinc-800/60 px-2 py-1.5 text-xs text-zinc-200 text-center focus:outline-none focus:border-emerald-500/50" />
          </div>
          <div class="flex items-center gap-1.5">
            <label class="text-[10px] text-zinc-600">Reps</label>
            <input type="number" value="${exercise.reps}" min="1" max="100" class="w-14 rounded-lg border border-zinc-800/40 bg-zinc-800/60 px-2 py-1.5 text-xs text-zinc-200 text-center focus:outline-none focus:border-emerald-500/50" />
          </div>
          <div class="flex items-center gap-1.5">
            <label class="text-[10px] text-zinc-600">Descanso</label>
            <input type="text" value="${exercise.restTime}" placeholder="60s" class="w-16 rounded-lg border border-zinc-800/40 bg-zinc-800/60 px-2 py-1.5 text-xs text-zinc-200 text-center focus:outline-none focus:border-emerald-500/50" />
          </div>
          <div class="flex-1 flex items-center gap-1.5">
            <label class="text-[10px] text-zinc-600">Notas</label>
            <input type="text" value="${escapeHtml(exercise.description || '')}" placeholder="Opcional" class="flex-1 min-w-0 rounded-lg border border-zinc-800/40 bg-zinc-800/60 px-2 py-1.5 text-xs text-zinc-200 placeholder-zinc-600 focus:outline-none focus:border-emerald-500/50" />
          </div>
        </div>
      </div>
    `;
  }
</script>