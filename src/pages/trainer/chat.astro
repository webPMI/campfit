---
import TrainerLayout from '@/layouts/TrainerLayout.astro';
import { translations, type Language } from '@/i18n/translations';

const lang = (Astro.url.searchParams.get('lang') as Language) || 'es';
const t = (key: string) => translations[lang]?.[key] || translations['es']?.[key] || key;
---

<TrainerLayout>
  <div class="mx-auto max-w-4xl px-4 py-8">
    <div class="animate-fade-in">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-bold">{t('trainer.chat')}</h1>
          <p class="mt-1 text-sm text-zinc-500">{t('trainer.chat.desc')}</p>
        </div>
      </div>

      <div class="mt-6 grid grid-cols-1 gap-4 lg:grid-cols-3">
        <!-- Conversation List -->
        <div class="lg:col-span-1">
          <div class="rounded-xl border border-zinc-800/40 bg-zinc-900/40 backdrop-blur-sm overflow-hidden">
            <div class="border-b border-zinc-800/40 p-3">
              <input id="chat-search" type="text" placeholder="Buscar conversaciones..." class="w-full rounded-lg border border-zinc-800/40 bg-zinc-800/60 px-3 py-2 text-xs text-zinc-200 placeholder-zinc-600 focus:outline-none focus:border-emerald-500/50" />
            </div>
            <div id="conversation-list" class="divide-y divide-zinc-800/40 max-h-[70vh] overflow-y-auto">
              <div class="p-6 text-center">
                <p class="text-xs text-zinc-500">Cargando...</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Chat View -->
        <div class="lg:col-span-2">
          <div id="chat-view" class="hidden rounded-xl border border-zinc-800/40 bg-zinc-900/40 backdrop-blur-sm overflow-hidden flex flex-col" style="height: min(70vh, 600px);">
            <!-- Chat Header -->
            <div id="chat-header" class="flex items-center gap-3 border-b border-zinc-800/40 p-4">
              <div class="flex h-9 w-9 items-center justify-center rounded-full bg-emerald-500/10 text-sm font-medium text-emerald-400">?</div>
              <div>
                <p class="text-sm font-medium text-zinc-200">Selecciona un chat</p>
                <p class="text-xs text-zinc-500">Inicia una conversación</p>
              </div>
            </div>

            <!-- Messages -->
            <div id="messages-container" class="flex-1 overflow-y-auto p-4 space-y-3">
              <div class="flex h-full items-center justify-center">
                <p class="text-sm text-zinc-600">Selecciona un cliente para chatear</p>
              </div>
            </div>

            <!-- Input -->
            <div class="border-t border-zinc-800/40 p-3">
              <div class="flex items-center gap-2">
                <input id="chat-input" type="text" placeholder="Escribe un mensaje..." class="flex-1 rounded-xl border border-zinc-800/40 bg-zinc-800/60 px-4 py-2.5 text-sm text-zinc-200 placeholder-zinc-600 focus:outline-none focus:border-emerald-500/50" />
                <button id="btn-send-message" class="rounded-xl bg-emerald-500/10 border border-emerald-500/20 px-4 py-2.5 text-sm font-medium text-emerald-400 hover:bg-emerald-500/20 transition-all disabled:opacity-40 disabled:cursor-not-allowed" disabled>
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
                  </svg>
                </button>
                <button id="btn-send-alert" class="rounded-xl bg-red-500/10 border border-red-500/20 px-3 py-2.5 text-sm font-medium text-red-400 hover:bg-red-500/20 transition-all disabled:opacity-40 disabled:cursor-not-allowed" title="Enviar llamado de atención" disabled>
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
                  </svg>
                </button>
              </div>
            </div>
          </div>

          <!-- Empty State -->
          <div id="chat-empty" class="rounded-xl border border-zinc-800/40 bg-zinc-900/40 p-8 text-center backdrop-blur-sm flex flex-col items-center justify-center" style="height: min(70vh, 600px);">
            <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-zinc-800/50">
              <svg class="h-7 w-7 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 0 1-.825-.242m9.345-8.334a2.126 2.126 0 0 0-.476-.095 48.64 48.64 0 0 0-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0 0 11.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155" />
              </svg>
            </div>
            <p class="text-sm text-zinc-500">Selecciona una conversación de la lista para comenzar a chatear</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</TrainerLayout>

<script>
  import { requireAuth } from '@/lib/shared/authGuard';
  import {
    subscribeToClients,
    subscribeToConversations,
    subscribeToConversation,
    sendMessage,
    markAsRead,
    ICONS,
    renderMessageBubble,
    escapeHtml,
    getUserInitial,
    formatTime,
  } from '@/lib/trainer/trainerUtils';
  import type { TrainerClient, TrainerMessage } from '@/lib/trainer/trainerUtils';

  requireAuth(async (user) => {
    initChat(user.uid);
  });

  let allClients: TrainerClient[] = [];
  let conversations: { clientId: string; lastMessage: TrainerMessage | null; unread: number }[] = [];
  let selectedClient: TrainerClient | null = null;
  let currentUnsub: (() => void) | null = null;
  let trainerId: string = '';

  async function initChat(uid: string): Promise<void> {
    trainerId = uid;
    const conversationList = document.getElementById('conversation-list')!;
    const chatView = document.getElementById('chat-view')!;
    const chatEmpty = document.getElementById('chat-empty')!;
    const messagesContainer = document.getElementById('messages-container')!;
    const chatInput = document.getElementById('chat-input') as HTMLInputElement;
    const btnSend = document.getElementById('btn-send-message')!;
    const btnAlert = document.getElementById('btn-send-alert')!;
    const chatSearch = document.getElementById('chat-search') as HTMLInputElement;

    // Subscribe to clients
    subscribeToClients(trainerId, (clients) => {
      allClients = clients;
      renderConversations();
    });

    // Subscribe to all messages for the trainer
    subscribeToConversations(trainerId, (messages) => {
      // Group by client
      const clientMap = new Map<string, TrainerMessage[]>();
      messages.forEach((m) => {
        const clientId = m.senderId === trainerId ? m.receiverId : m.senderId;
        if (!clientMap.has(clientId)) clientMap.set(clientId, []);
        clientMap.get(clientId)!.push(m);
      });

      conversations = Array.from(clientMap.entries())
        .map(([clientId, msgs]) => {
          const sorted = msgs.sort((a, b) => {
            const timeA = a.createdAt?.toDate?.()?.getTime() || 0;
            const timeB = b.createdAt?.toDate?.()?.getTime() || 0;
            return timeB - timeA;
          });
          return {
            clientId,
            lastMessage: sorted[0] || null,
            unread: msgs.filter((m) => m.receiverId === trainerId && !m.isRead).length,
          };
        })
        .sort((a, b) => {
          const timeA = a.lastMessage?.createdAt?.toDate?.()?.getTime() || 0;
          const timeB = b.lastMessage?.createdAt?.toDate?.()?.getTime() || 0;
          return timeB - timeA;
        });

      renderConversations();
    });

    // Search filter
    chatSearch.addEventListener('input', () => renderConversations());

    // Send message
    btnSend.addEventListener('click', async () => {
      const content = chatInput.value.trim();
      if (!content || !selectedClient) return;
      const ok = await sendMessage(trainerId, selectedClient.uid, content, 'text');
      if (ok) {
        chatInput.value = '';
        scrollToBottom();
      }
    });

    // Send alert
    btnAlert.addEventListener('click', async () => {
      const content = chatInput.value.trim();
      if (!content || !selectedClient) return;
      const ok = await sendMessage(trainerId, selectedClient.uid, content, 'alert');
      if (ok) {
        chatInput.value = '';
        scrollToBottom();
      }
    });

    // Enter key
    chatInput.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') btnSend.click();
    });
  }

  function renderConversations(): void {
    const conversationList = document.getElementById('conversation-list')!;
    const searchTerm = (document.getElementById('chat-search') as HTMLInputElement).value.toLowerCase();

    if (conversations.length === 0) {
      conversationList.innerHTML = `
        <div class="p-6 text-center">
          <p class="text-xs text-zinc-500">Sin conversaciones aún</p>
          <p class="text-xs text-zinc-600 mt-1">Los mensajes aparecerán aquí</p>
        </div>
      `;
      return;
    }

    // Filter by search and also include clients with no messages yet
    const displayItems = conversations.filter((c) => {
      const client = allClients.find((cl) => cl.uid === c.clientId);
      const name = client?.name?.toLowerCase() || '';
      return name.includes(searchTerm);
    });

    if (displayItems.length === 0) {
      conversationList.innerHTML = `<div class="p-6 text-center"><p class="text-xs text-zinc-500">Sin resultados</p></div>`;
      return;
    }

    conversationList.innerHTML = displayItems
      .map((c) => {
        const client = allClients.find((cl) => cl.uid === c.clientId);
        const name = client?.name || 'Usuario';
        const initial = getUserInitial(name);
        const hasAlert = client?.hasActiveAlert;
        const lastMsg = c.lastMessage?.content || 'Sin mensajes';
        const time = c.lastMessage ? formatTime(c.lastMessage.createdAt) : '';
        const isSelected = selectedClient?.uid === c.clientId;

        return `
          <div class="flex items-center gap-3 p-3 cursor-pointer transition-all hover:bg-zinc-800/40 ${isSelected ? 'bg-zinc-800/40' : ''}" onclick="window.__selectConversation('${c.clientId}')">
            <div class="relative shrink-0">
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-emerald-500/10 text-sm font-medium text-emerald-400">
                ${initial}
              </div>
              ${hasAlert ? '<div class="absolute -right-0.5 -top-0.5 h-3 w-3 rounded-full bg-red-500 animate-pulse border-2 border-zinc-900"></div>' : ''}
            </div>
            <div class="min-w-0 flex-1">
              <div class="flex items-center justify-between">
                <p class="text-sm font-medium text-zinc-200 truncate">${escapeHtml(name)}</p>
                <span class="text-[10px] text-zinc-600 shrink-0 ml-2">${time}</span>
              </div>
              <div class="flex items-center justify-between mt-0.5">
                <p class="text-xs text-zinc-500 truncate">${escapeHtml(lastMsg.substring(0, 40))}${lastMsg.length > 40 ? '...' : ''}</p>
                ${c.unread > 0 ? `<span class="flex h-4 w-4 items-center justify-center rounded-full bg-emerald-500 text-[9px] font-bold text-white shrink-0 ml-2">${c.unread}</span>` : ''}
              </div>
            </div>
          </div>
        `;
      })
      .join('');
  }

  (window as any).__selectConversation = (clientId: string) => {
    const client = allClients.find((c) => c.uid === clientId);
    if (!client) return;
    selectedClient = client;

    const chatView = document.getElementById('chat-view')!;
    const chatEmpty = document.getElementById('chat-empty')!;
    const messagesContainer = document.getElementById('messages-container')!;
    const chatHeader = document.getElementById('chat-header')!;
    const chatInput = document.getElementById('chat-input') as HTMLInputElement;
    const btnSend = document.getElementById('btn-send-message')!;
    const btnAlert = document.getElementById('btn-send-alert')!;

    chatView.classList.remove('hidden');
    chatEmpty.classList.add('hidden');
    btnSend.removeAttribute('disabled');
    btnAlert.removeAttribute('disabled');
    chatInput.removeAttribute('disabled');
    chatInput.focus();

    // Update header
    chatHeader.innerHTML = `
      <div class="flex h-9 w-9 items-center justify-center rounded-full bg-emerald-500/10 text-sm font-medium text-emerald-400">
        ${getUserInitial(client.name)}
      </div>
      <div>
        <p class="text-sm font-medium text-zinc-200">${escapeHtml(client.name)}</p>
        <p class="text-xs text-zinc-500">${escapeHtml(client.email)}</p>
      </div>
    `;

    // Unsub previous
    if (currentUnsub) currentUnsub();
    currentUnsub = null;

    // Subscribe to conversation
    currentUnsub = subscribeToConversation(trainerId, clientId, (messages) => {
      if (messages.length === 0) {
        messagesContainer.innerHTML = `
          <div class="flex h-full items-center justify-center">
            <p class="text-sm text-zinc-600">No hay mensajes aún. ¡Envía el primero!</p>
          </div>
        `;
        return;
      }

      // Mark incoming messages as read
      messages.forEach((m) => {
        if (m.receiverId === trainerId && !m.isRead) {
          markAsRead(m.id);
        }
      });

      messagesContainer.innerHTML = messages
        .map((m, idx) => {
          const isOwn = m.senderId === trainerId;
          const prevMsg = idx > 0 ? messages[idx - 1] : null;
          const isFirstOfBlock = !prevMsg || prevMsg.senderId !== m.senderId;
          return renderMessageBubble(m, isOwn, client.name, isFirstOfBlock);
        })
        .join('');

      scrollToBottom();
    });

    renderConversations();
  };

  function scrollToBottom(): void {
    const container = document.getElementById('messages-container')!;
    setTimeout(() => {
      container.scrollTop = container.scrollHeight;
    }, 50);
  }
</script>