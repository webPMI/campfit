---
import TrainerLayout from '@/layouts/TrainerLayout.astro';
import { translations, type Language } from '@/i18n/translations';

const lang = (Astro.url.searchParams.get('lang') as Language) || 'es';
const t = (key: string) => translations[lang]?.[key] || translations['es']?.[key] || key;
---

<TrainerLayout>
  <div class="mx-auto max-w-4xl px-4 py-8">
    <div class="animate-fade-in">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-bold">{t('trainer.dashboard')}</h1>
          <p class="mt-1 text-sm text-zinc-500">{t('trainer.clients.desc')}</p>
        </div>
        <div id="last-update" class="text-xs text-zinc-600"></div>
      </div>

      <!-- Stats Grid -->
      <div class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-4">
        <div class="rounded-xl border border-zinc-800/40 bg-zinc-900/40 p-4 backdrop-blur-sm">
          <div class="mb-2 flex h-8 w-8 items-center justify-center rounded-lg bg-emerald-500/10">
            <svg class="h-4 w-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
            </svg>
          </div>
          <p class="text-xs font-semibold text-zinc-400">{t('trainer.clients')}</p>

          <p id="stat-total-clients" class="mt-0.5 text-xl font-bold text-emerald-400">-</p>
        </div>

        <div class="rounded-xl border border-zinc-800/40 bg-zinc-900/40 p-4 backdrop-blur-sm">
          <div class="mb-2 flex h-8 w-8 items-center justify-center rounded-lg bg-blue-500/10">
            <svg class="h-4 w-4 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 0 1-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 0 0 6.16-12.12A14.98 14.98 0 0 0 9.631 8.41m5.96 5.96a14.926 14.926 0 0 1-5.841 2.58m-.119-8.54a6 6 0 0 0-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 0 0-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 0 1-2.448-2.448 14.9 14.9 0 0 1 .06-.312m-2.24 2.39a4.493 4.493 0 0 0-1.757 4.306 4.493 4.493 0 0 0 4.306-1.758M16.5 9a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0Z" />
            </svg>
          </div>
          <p class="text-xs font-semibold text-zinc-400">{t('trainer.workouts')}</p>
          <p id="stat-total-workouts" class="mt-0.5 text-xl font-bold text-blue-400">-</p>
        </div>

        <div class="rounded-xl border border-zinc-800/40 bg-zinc-900/40 p-4 backdrop-blur-sm">
          <div class="mb-2 flex h-8 w-8 items-center justify-center rounded-lg bg-orange-500/10">
            <svg class="h-4 w-4 text-orange-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8.25v-1.5m0 1.5c-1.355 0-2.697.056-4.024.166C6.845 8.51 6 9.473 6 10.608v2.513m6-4.871c1.355 0 2.697.056 4.024.166C17.155 8.51 18 9.473 18 10.608v2.513M15 8.25v-1.5m-6 1.5v-1.5m12 9.75-1.5.75a3.354 3.354 0 0 1-3 0 3.354 3.354 0 0 0-3 0 3.354 3.354 0 0 1-3 0 3.354 3.354 0 0 0-3 0 3.354 3.354 0 0 1-3 0L3 16.5m15-3.38a48.474 48.474 0 0 0-6-.37c-2.032 0-4.034.125-6 .37m12 0c.39.049.777.102 1.163.16 1.07.16 1.837 1.094 1.837 2.175v5.169c0 .621-.504 1.125-1.125 1.125H4.125A1.125 1.125 0 0 1 3 20.625v-5.17c0-1.08.768-2.014 1.837-2.174A47.78 47.78 0 0 1 6 13.12M12.265 3.11a.375.375 0 1 1-.53 0L12 2.845l.265.265Zm-3 0a.375.375 0 1 1-.53 0L9 2.845l.265.265Zm6 0a.375.375 0 1 1-.53 0L15 2.845l.265.265Z" />
            </svg>
          </div>
          <p class="text-xs font-semibold text-zinc-400">{t('trainer.diets')}</p>
          <p id="stat-total-diets" class="mt-0.5 text-xl font-bold text-orange-400">-</p>
        </div>

        <div class="rounded-xl border border-zinc-800/40 bg-zinc-900/40 p-4 backdrop-blur-sm">
          <div class="mb-2 flex h-8 w-8 items-center justify-center rounded-lg bg-rose-500/10">
            <svg class="h-4 w-4 text-rose-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 0 1-.825-.242m9.345-8.334a2.126 2.126 0 0 0-.476-.095 48.64 48.64 0 0 0-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0 0 11.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155" />
            </svg>
          </div>
          <p class="text-xs font-semibold text-zinc-400">{t('trainer.chat')}</p>
          <p id="stat-unread-messages" class="mt-0.5 text-xl font-bold text-rose-400">-</p>
        </div>
      </div>

      <!-- Clients Section -->
      <div class="mt-8">
        <div class="flex items-center justify-between">
          <h2 class="text-lg font-semibold text-zinc-200">{t('trainer.clients')}</h2>
          <a href={`/trainer/clients?lang=${lang}`} class="text-xs text-emerald-400 hover:text-emerald-300 transition-colors">{t('admin.all')} →</a>
        </div>
        <div id="clients-list" class="mt-4 space-y-3">
          <div class="rounded-xl border border-zinc-800/40 bg-zinc-900/40 p-6 text-center backdrop-blur-sm">
            <div class="flex items-center justify-center gap-3">
              <svg class="h-5 w-5 animate-spin text-emerald-400" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z" />
              </svg>
              <p class="text-sm text-zinc-500">{t('admin.loading')}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Alerts Section -->
      <div class="mt-8">
        <div class="flex items-center justify-between">
          <h2 class="text-lg font-semibold text-zinc-200">{t('admin.alert.active')}</h2>
          <a href={`/trainer/chat?lang=${lang}`} class="text-xs text-emerald-400 hover:text-emerald-300 transition-colors">{t('trainer.chat')} →</a>
        </div>
        <div id="alerts-section" class="mt-4 space-y-3">
          <div class="rounded-xl border border-zinc-800/40 bg-zinc-900/40 p-6 text-center backdrop-blur-sm">
            <p class="text-sm text-zinc-500">Sin alertas activas</p>
          </div>
        </div>
      </div>

      <!-- Workouts & Diets Grid -->
      <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2">
        <div>
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-semibold text-zinc-200">{t('trainer.workouts')}</h2>
            <a href={`/trainer/workouts?lang=${lang}`} class="text-xs text-emerald-400 hover:text-emerald-300 transition-colors">{t('admin.all')} →</a>
          </div>
          <div id="workouts-preview" class="space-y-3">
            <div class="rounded-xl border border-zinc-800/40 bg-zinc-900/40 p-6 text-center backdrop-blur-sm">
              <div class="flex items-center justify-center gap-3">
                <svg class="h-5 w-5 animate-spin text-emerald-400" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z" />
                </svg>
                <p class="text-sm text-zinc-500">{t('admin.loading')}</p>
              </div>
            </div>
          </div>
        </div>

        <div>
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-semibold text-zinc-200">{t('trainer.diets')}</h2>
            <a href={`/trainer/diets?lang=${lang}`} class="text-xs text-emerald-400 hover:text-emerald-300 transition-colors">{t('admin.all')} →</a>
          </div>
          <div id="diets-preview" class="space-y-3">
            <div class="rounded-xl border border-zinc-800/40 bg-zinc-900/40 p-6 text-center backdrop-blur-sm">
              <div class="flex items-center justify-center gap-3">
                <svg class="h-5 w-5 animate-spin text-emerald-400" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z" />
                </svg>
                <p class="text-sm text-zinc-500">{t('admin.loading')}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</TrainerLayout>

<script>
  import { requireAuth } from '@/lib/shared/authGuard';
  import {
    subscribeToClients,
    subscribeToWorkoutsByTrainer,
    subscribeToDietsByTrainer,
    subscribeToConversations,
    ICONS,
    renderEmptyState,
    renderClientCard,
    renderWorkoutCard,
    renderDietCard,
    escapeHtml,
  } from '@/lib/trainer/trainerUtils';

  let unsubClients: (() => void) | null = null;
  let unsubWorkouts: (() => void) | null = null;
  let unsubDiets: (() => void) | null = null;
  let unsubMessages: (() => void) | null = null;

  requireAuth(async (user) => {
    const lang = new URLSearchParams(window.location.search).get('lang') || 'es';
    initDashboard(user.uid, lang);
  });

  // Cleanup subscriptions on page unload
  window.addEventListener('beforeunload', () => {
    unsubClients?.();
    unsubWorkouts?.();
    unsubDiets?.();
    unsubMessages?.();
  });

  async function initDashboard(trainerId: string, lang: string): Promise<void> {
    const statClients = document.getElementById('stat-total-clients')!;
    const statWorkouts = document.getElementById('stat-total-workouts')!;
    const statDiets = document.getElementById('stat-total-diets')!;
    const statUnread = document.getElementById('stat-unread-messages')!;
    const clientsContainer = document.getElementById('clients-list')!;
    const workoutsContainer = document.getElementById('workouts-preview')!;
    const dietsContainer = document.getElementById('diets-preview')!;
    const alertsContainer = document.getElementById('alerts-section')!;
    const lastUpdateEl = document.getElementById('last-update')!;

    function updateTimestamp(label?: string): void {
      const now = new Date();
      const time = now.toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit' });
      lastUpdateEl.textContent = label
        ? `📡 ${label} · ${time}`
        : `🕐 ${time}`;
    }

    try {
      // Subscribe to clients
      unsubClients = subscribeToClients(trainerId, (clients) => {
        statClients.textContent = String(clients.length);
        statClients.classList.remove('text-emerald-400');
        // Force reflow for animation
        void statClients.offsetWidth;
        statClients.classList.add('text-emerald-400');

        if (clients.length === 0) {
          clientsContainer.innerHTML = renderEmptyState(ICONS.users, 'No tienes clientes asignados');
        } else {
          clientsContainer.innerHTML = clients.slice(0, 5).map((c) =>
            renderClientCard(c, `window.location.href='/trainer/clients?lang=${lang}'`)
          ).join('');
        }

        // Render alerts for clients with active alerts
        const alertedClients = clients.filter((c) => c.hasActiveAlert);
        if (alertedClients.length === 0) {
          alertsContainer.innerHTML = `
            <div class="rounded-xl border border-zinc-800/40 bg-zinc-900/40 p-4 backdrop-blur-sm">
              <div class="flex items-center gap-3">
                <div class="flex h-8 w-8 items-center justify-center rounded-full bg-emerald-500/10">
                  <svg class="h-4 w-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                  </svg>
                </div>
                <p class="text-sm text-zinc-500">Sin alertas activas</p>
              </div>
            </div>
          `;
        } else {
          alertsContainer.innerHTML = alertedClients.map((c) => `
            <div class="rounded-xl border border-red-900/30 bg-red-500/5 p-4 backdrop-blur-sm cursor-pointer hover:bg-red-500/10 transition-all"
                 onclick="window.location.href='/trainer/chat?lang=${lang}'">
              <div class="flex items-center gap-3">
                <div class="flex h-8 w-8 items-center justify-center rounded-full bg-red-500/10 shrink-0">
                  <svg class="h-4 w-4 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-medium text-zinc-200">${escapeHtml(c.name)}</p>
                  <p class="text-xs text-red-400/70">Alerta activa — Haz clic para ir al chat</p>
                </div>
              </div>
            </div>
          `).join('');
        }

        updateTimestamp('clientes');
      });

      // Subscribe to workouts
      unsubWorkouts = subscribeToWorkoutsByTrainer(trainerId, (workouts) => {
        statWorkouts.textContent = String(workouts.length);

        if (workouts.length === 0) {
          workoutsContainer.innerHTML = renderEmptyState(ICONS.workouts, 'No has creado rutinas aún');
        } else {
          workoutsContainer.innerHTML = workouts.slice(0, 3).map((w) => renderWorkoutCard(w)).join('');
        }

        updateTimestamp('rutinas');
      });

      // Subscribe to diets
      unsubDiets = subscribeToDietsByTrainer(trainerId, (diets) => {
        statDiets.textContent = String(diets.length);

        if (diets.length === 0) {
          dietsContainer.innerHTML = renderEmptyState(ICONS.diets, 'No has creado dietas aún');
        } else {
          dietsContainer.innerHTML = diets.slice(0, 3).map((d) => renderDietCard(d)).join('');
        }

        updateTimestamp('dietas');
      });

      // Subscribe to messages for unread count
      unsubMessages = subscribeToConversations(trainerId, (messages) => {
        const unread = messages.filter((m) => m.receiverId === trainerId && !m.isRead).length;

        statUnread.textContent = String(unread);
        statUnread.classList.toggle('text-rose-400', unread === 0);
        statUnread.classList.toggle('text-rose-300', unread > 0);
      });

    } catch (error) {
      console.error('[TrainerDashboard] Error initializing:', error);
      clientsContainer.innerHTML = `
        <div class="rounded-xl border border-red-900/30 bg-red-500/5 p-6 text-center backdrop-blur-sm">
          <p class="text-sm text-red-400">Error al cargar el dashboard. Recarga la página.</p>
        </div>
      `;
    }
  }
</script>