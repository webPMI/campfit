---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { translations, type Language } from '@/i18n/translations';

const lang = (Astro.url.searchParams.get('lang') as Language) || 'es';
const t = (key: string) => translations[lang]?.[key] || translations['es']?.[key] || key;
const altLang = lang === 'es' ? 'en' : 'es';
---

<BaseLayout>
  <div class="flex min-h-screen flex-col items-center justify-center px-4 py-12 text-center">
    <!-- Fondo decorativo -->
    <div class="pointer-events-none fixed inset-0 overflow-hidden">
      <div class="absolute -left-40 -top-40 h-80 w-80 rounded-full bg-emerald-500/5 blur-3xl"></div>
      <div class="absolute -bottom-40 -right-40 h-80 w-80 rounded-full bg-emerald-500/5 blur-3xl"></div>
    </div>

    <!-- Language Switcher -->
    <div class="fixed right-4 top-4 z-50">
      <a
        href={`/?lang=${altLang}`}
        class="inline-flex items-center gap-1.5 rounded-xl border border-zinc-700/50 bg-zinc-900/80 px-3 py-2 text-xs font-medium text-zinc-400 backdrop-blur-sm transition-all hover:border-zinc-600 hover:text-zinc-200"
      >
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418" />
        </svg>
        {altLang === 'en' ? 'EN' : 'ES'}
      </a>
    </div>

    <div class="w-full max-w-lg animate-fade-in">
      <!-- Logo -->
      <div class="mb-8 text-center">
        <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-emerald-400 to-emerald-600 shadow-lg shadow-emerald-500/20">
          <svg class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 0 1-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 0 0 6.16-12.12A14.98 14.98 0 0 0 9.631 8.41m5.96 5.96a14.926 14.926 0 0 1-5.841 2.58m-.119-8.54a6 6 0 0 0-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 0 0-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 0 1-2.448-2.448 14.9 14.9 0 0 1 .06-.312m-2.24 2.39a4.493 4.493 0 0 0-1.757 4.306 4.493 4.493 0 0 0 4.306-1.758M16.5 9a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0Z" />
          </svg>
        </div>
        <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{t('app.name')}</h1>
        <p class="mt-1 text-sm text-zinc-500">{t('app.tagline')}</p>
      </div>

      <!-- Card -->
      <div class="card-glow rounded-2xl border border-zinc-800/60 bg-zinc-900/80 p-10 backdrop-blur-xl">
        <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
          {t('hero.title')}
          <span class="text-emerald-400"> {t('hero.title.highlight')}</span>
        </h2>

        <p class="mt-4 text-base text-zinc-400 leading-relaxed">
          {t('hero.description')}
        </p>

        <div class="mt-8 flex flex-col gap-4 sm:flex-row sm:justify-center">
          <a
            href={`/register?lang=${lang}`}
            class="inline-flex items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-emerald-500 to-emerald-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-emerald-500/20 transition-all hover:from-emerald-400 hover:to-emerald-500 hover:shadow-emerald-500/30 active:scale-[0.98]"
          >
            {t('hero.cta')}
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <a
            href={`/login?lang=${lang}`}
            class="inline-flex items-center justify-center gap-2 rounded-xl border border-zinc-700/50 bg-zinc-800/50 px-6 py-3 text-sm font-medium text-zinc-300 transition-all hover:border-zinc-600 hover:bg-zinc-800 hover:text-white active:scale-[0.98]"
          >
            {t('hero.login')}
          </a>
        </div>
      </div>

      <!-- Features -->
      <div class="mt-12 grid grid-cols-1 gap-4 sm:grid-cols-3">
        <div class="animate-fade-in-delay rounded-xl border border-zinc-800/40 bg-zinc-900/40 p-5 text-left backdrop-blur-sm">
          <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-emerald-500/10">
            <svg class="h-5 w-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" />
            </svg>
          </div>
          <h3 class="text-sm font-semibold text-zinc-200">{t('feature.training')}</h3>
          <p class="mt-1 text-xs text-zinc-500">{t('feature.training.desc')}</p>
        </div>

        <div class="animate-fade-in-delay rounded-xl border border-zinc-800/40 bg-zinc-900/40 p-5 text-left backdrop-blur-sm" style="animation-delay: 0.1s">
          <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-emerald-500/10">
            <svg class="h-5 w-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
          </div>
          <h3 class="text-sm font-semibold text-zinc-200">{t('feature.tracking')}</h3>
          <p class="mt-1 text-xs text-zinc-500">{t('feature.tracking.desc')}</p>
        </div>

        <div class="animate-fade-in-delay rounded-xl border border-zinc-800/40 bg-zinc-900/40 p-5 text-left backdrop-blur-sm" style="animation-delay: 0.2s">
          <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-emerald-500/10">
            <svg class="h-5 w-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
            </svg>
          </div>
          <h3 class="text-sm font-semibold text-zinc-200">{t('feature.coach')}</h3>
          <p class="mt-1 text-xs text-zinc-500">{t('feature.coach.desc')}</p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
