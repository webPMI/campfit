---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { translations, type Language } from '@/i18n/translations';

const lang = (Astro.url.searchParams.get('lang') as Language) || 'es';
const t = (key: string) => translations[lang]?.[key] || translations['es']?.[key] || key;
const altLang = lang === 'es' ? 'en' : 'es';
---

<BaseLayout>
  <div class="flex min-h-screen flex-col items-center justify-center px-4 py-12">
    <!-- Fondo decorativo -->
    <div class="pointer-events-none fixed inset-0 overflow-hidden">
      <div class="absolute -left-40 -top-40 h-80 w-80 rounded-full bg-emerald-500/5 blur-3xl"></div>
      <div class="absolute -bottom-40 -right-40 h-80 w-80 rounded-full bg-emerald-500/5 blur-3xl"></div>
    </div>

    <!-- Language Switcher -->
    <div class="fixed right-4 top-4 z-50">
      <a
        href={`/onboarding?lang=${altLang}`}
        class="inline-flex items-center gap-1.5 rounded-xl border border-zinc-700/50 bg-zinc-900/80 px-3 py-2 text-xs font-medium text-zinc-400 backdrop-blur-sm transition-all hover:border-zinc-600 hover:text-zinc-200"
      >
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418" />
        </svg>
        {altLang === 'en' ? 'EN' : 'ES'}
      </a>
    </div>

    <div class="w-full max-w-lg animate-fade-in">
      <!-- Header -->
      <div class="mb-8 text-center">
        <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-emerald-400 to-emerald-600 shadow-lg shadow-emerald-500/20">
          <svg class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
          </svg>
        </div>
        <h1 class="text-2xl font-bold tracking-tight">{t('onboarding.title')}</h1>
        <p class="mt-1 text-sm text-zinc-500">{t('onboarding.subtitle')}</p>
      </div>

      <!-- Progress Bar -->
      <div class="mb-6">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs text-zinc-500">
            <span id="stepLabel">{t('onboarding.step')} <span id="currentStep">1</span> {t('onboarding.of')} <span id="totalSteps">3</span></span>
          </span>
          <button id="skipBtn" class="text-xs text-zinc-600 hover:text-zinc-400 transition-colors">
            {t('onboarding.skip')}
          </button>
        </div>
        <div class="h-1.5 overflow-hidden rounded-full bg-zinc-800">
          <div id="progressBar" class="h-full rounded-full bg-gradient-to-r from-emerald-500 to-emerald-400 transition-all duration-500" style="width: 33.33%"></div>
        </div>
      </div>

      <!-- Card Container -->
      <div class="card-glow rounded-2xl border border-zinc-800/60 bg-zinc-900/80 p-8 backdrop-blur-xl">
        <!-- Step 1: Personal Info -->
        <div id="step1" class="step-content">
          <h2 class="text-lg font-semibold mb-1">{t('onboarding.personal.title')}</h2>
          <p class="text-sm text-zinc-500 mb-6">{t('onboarding.personal.desc')}</p>

          <div class="space-y-4">
            <div>
              <label for="birthdate" class="block text-sm font-medium text-zinc-400 mb-1.5">{t('onboarding.birthdate')}</label>
              <input
                id="birthdate"
                type="date"
                class="w-full rounded-xl border border-zinc-700/50 bg-zinc-800/50 px-4 py-3 text-sm text-zinc-100 outline-none transition-all focus:border-emerald-500/50 focus:ring-2 focus:ring-emerald-500/10"
              />
            </div>

            <div>
              <label for="height" class="block text-sm font-medium text-zinc-400 mb-1.5">{t('client.medical.height')}</label>
              <input
                id="height"
                type="number"
                step="0.1"
                placeholder="175"
                class="w-full rounded-xl border border-zinc-700/50 bg-zinc-800/50 px-4 py-3 text-sm text-zinc-100 placeholder-zinc-600 outline-none transition-all focus:border-emerald-500/50 focus:ring-2 focus:ring-emerald-500/10"
              />
            </div>

            <div>
              <label for="weight" class="block text-sm font-medium text-zinc-400 mb-1.5">{t('client.medical.weight')}</label>
              <input
                id="weight"
                type="number"
                step="0.1"
                placeholder="75"
                class="w-full rounded-xl border border-zinc-700/50 bg-zinc-800/50 px-4 py-3 text-sm text-zinc-100 placeholder-zinc-600 outline-none transition-all focus:border-emerald-500/50 focus:ring-2 focus:ring-emerald-500/10"
              />
            </div>

            <div>
              <label for="experience" class="block text-sm font-medium text-zinc-400 mb-1.5">{t('onboarding.experience')}</label>
              <select
                id="experience"
                class="w-full rounded-xl border border-zinc-700/50 bg-zinc-800/50 px-4 py-3 text-sm text-zinc-100 outline-none transition-all focus:border-emerald-500/50 focus:ring-2 focus:ring-emerald-500/10"
              >
                <option value="">Seleccionar</option>
                <option value="beginner">{t('onboarding.experience.beginner')}</option>
                <option value="intermediate">{t('onboarding.experience.intermediate')}</option>
                <option value="advanced">{t('onboarding.experience.advanced')}</option>
              </select>
            </div>

            <div>
              <label class="block text-sm font-medium text-zinc-400 mb-2">{t('onboarding.goals')}</label>
              <div class="grid grid-cols-2 gap-2">
                <label class="flex items-center gap-2 rounded-xl border border-zinc-700/50 bg-zinc-800/30 px-3 py-2.5 cursor-pointer transition-all hover:border-zinc-600 has-[:checked]:border-emerald-500/50 has-[:checked]:bg-emerald-500/5">
                  <input type="checkbox" value="lose_weight" class="accent-emerald-500" />
                  <span class="text-sm text-zinc-300">{t('onboarding.goals.lose_weight')}</span>
                </label>
                <label class="flex items-center gap-2 rounded-xl border border-zinc-700/50 bg-zinc-800/30 px-3 py-2.5 cursor-pointer transition-all hover:border-zinc-600 has-[:checked]:border-emerald-500/50 has-[:checked]:bg-emerald-500/5">
                  <input type="checkbox" value="gain_muscle" class="accent-emerald-500" />
                  <span class="text-sm text-zinc-300">{t('onboarding.goals.gain_muscle')}</span>
                </label>
                <label class="flex items-center gap-2 rounded-xl border border-zinc-700/50 bg-zinc-800/30 px-3 py-2.5 cursor-pointer transition-all hover:border-zinc-600 has-[:checked]:border-emerald-500/50 has-[:checked]:bg-emerald-500/5">
                  <input type="checkbox" value="endurance" class="accent-emerald-500" />
                  <span class="text-sm text-zinc-300">{t('onboarding.goals.endurance')}</span>
                </label>
                <label class="flex items-center gap-2 rounded-xl border border-zinc-700/50 bg-zinc-800/30 px-3 py-2.5 cursor-pointer transition-all hover:border-zinc-600 has-[:checked]:border-emerald-500/50 has-[:checked]:bg-emerald-500/5">
                  <input type="checkbox" value="strength" class="accent-emerald-500" />
                  <span class="text-sm text-zinc-300">{t('onboarding.goals.strength')}</span>
                </label>
                <label class="col-span-2 flex items-center gap-2 rounded-xl border border-zinc-700/50 bg-zinc-800/30 px-3 py-2.5 cursor-pointer transition-all hover:border-zinc-600 has-[:checked]:border-emerald-500/50 has-[:checked]:bg-emerald-500/5">
                  <input type="checkbox" value="health" class="accent-emerald-500" />
                  <span class="text-sm text-zinc-300">{t('onboarding.goals.health')}</span>
                </label>
              </div>
            </div>
          </div>
        </div>

        <!-- Step 2: Medical Profile -->
        <div id="step2" class="step-content hidden">
          <h2 class="text-lg font-semibold mb-1">{t('onboarding.medical.title')}</h2>
          <p class="text-sm text-zinc-500 mb-6">{t('onboarding.medical.desc')}</p>

          <div class="space-y-4">
            <div>
              <label for="conditions" class="block text-sm font-medium text-zinc-400 mb-1.5">{t('onboarding.conditions')}</label>
              <textarea
                id="conditions"
                rows="2"
                placeholder="Ej: Asma, diabetes, hipertensión"
                class="w-full rounded-xl border border-zinc-700/50 bg-zinc-800/50 px-4 py-3 text-sm text-zinc-100 placeholder-zinc-600 outline-none transition-all focus:border-emerald-500/50 focus:ring-2 focus:ring-emerald-500/10 resize-none"
              ></textarea>
            </div>
            <div>
              <label for="medications" class="block text-sm font-medium text-zinc-400 mb-1.5">{t('onboarding.medications')}</label>
              <textarea
                id="medications"
                rows="2"
                placeholder="Ej: Ibuprofeno, omeprazol"
                class="w-full rounded-xl border border-zinc-700/50 bg-zinc-800/50 px-4 py-3 text-sm text-zinc-100 placeholder-zinc-600 outline-none transition-all focus:border-emerald-500/50 focus:ring-2 focus:ring-emerald-500/10 resize-none"
              ></textarea>
            </div>
            <div>
              <label for="allergies" class="block text-sm font-medium text-zinc-400 mb-1.5">{t('onboarding.allergies')}</label>
              <textarea
                id="allergies"
                rows="2"
                placeholder="Ej: Polen, mariscos, penicilina"
                class="w-full rounded-xl border border-zinc-700/50 bg-zinc-800/50 px-4 py-3 text-sm text-zinc-100 placeholder-zinc-600 outline-none transition-all focus:border-emerald-500/50 focus:ring-2 focus:ring-emerald-500/10 resize-none"
              ></textarea>
            </div>
            <div>
              <label for="injuries" class="block text-sm font-medium text-zinc-400 mb-1.5">{t('onboarding.injuries')}</label>
              <textarea
                id="injuries"
                rows="2"
                placeholder="Ej: Esguince de tobillo, fractura"
                class="w-full rounded-xl border border-zinc-700/50 bg-zinc-800/50 px-4 py-3 text-sm text-zinc-100 placeholder-zinc-600 outline-none transition-all focus:border-emerald-500/50 focus:ring-2 focus:ring-emerald-500/10 resize-none"
              ></textarea>
            </div>
            <div>
              <label for="surgery" class="block text-sm font-medium text-zinc-400 mb-1.5">{t('onboarding.surgery')}</label>
              <textarea
                id="surgery"
                rows="2"
                placeholder="Ej: Cirugía de rodilla, apendicitis"
                class="w-full rounded-xl border border-zinc-700/50 bg-zinc-800/50 px-4 py-3 text-sm text-zinc-100 placeholder-zinc-600 outline-none transition-all focus:border-emerald-500/50 focus:ring-2 focus:ring-emerald-500/10 resize-none"
              ></textarea>
            </div>
          </div>
        </div>

        <!-- Step 3: Emergency Contact -->
        <div id="step3" class="step-content hidden">
          <h2 class="text-lg font-semibold mb-1">{t('onboarding.emergency.title')}</h2>
          <p class="text-sm text-zinc-500 mb-6">{t('onboarding.emergency.desc')}</p>

          <div class="space-y-4">
            <div>
              <label for="emergencyName" class="block text-sm font-medium text-zinc-400 mb-1.5">{t('client.medical.emergency.name')}</label>
              <input
                id="emergencyName"
                type="text"
                placeholder="María García"
                class="w-full rounded-xl border border-zinc-700/50 bg-zinc-800/50 px-4 py-3 text-sm text-zinc-100 placeholder-zinc-600 outline-none transition-all focus:border-emerald-500/50 focus:ring-2 focus:ring-emerald-500/10"
              />
            </div>
            <div>
              <label for="emergencyPhone" class="block text-sm font-medium text-zinc-400 mb-1.5">{t('client.medical.emergency.phone')}</label>
              <input
                id="emergencyPhone"
                type="tel"
                placeholder="+34 600 000 000"
                class="w-full rounded-xl border border-zinc-700/50 bg-zinc-800/50 px-4 py-3 text-sm text-zinc-100 placeholder-zinc-600 outline-none transition-all focus:border-emerald-500/50 focus:ring-2 focus:ring-emerald-500/10"
              />
            </div>
          </div>
        </div>

        <!-- Navigation Buttons -->
        <div class="mt-8 flex items-center gap-3">
          <button
            id="backBtn"
            class="hidden rounded-xl border border-zinc-700/50 bg-zinc-800/50 px-5 py-3 text-sm font-medium text-zinc-300 transition-all hover:border-zinc-600 hover:bg-zinc-800 active:scale-[0.98]"
          >
            {t('onboarding.back')}
          </button>
          <button
            id="nextBtn"
            class="flex-1 rounded-xl bg-gradient-to-r from-emerald-500 to-emerald-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-emerald-500/20 transition-all hover:from-emerald-400 hover:to-emerald-500 active:scale-[0.98]"
          >
            {t('onboarding.next')}
          </button>
        </div>

        <!-- Error -->
        <div id="errorMsg" class="mt-4 hidden items-center gap-2 rounded-xl bg-red-500/10 border border-red-500/20 px-4 py-3 text-sm text-red-400">
          <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
          </svg>
          <span id="errorText"></span>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import { authService } from '@/services/authService';
  import { doc, updateDoc, serverTimestamp } from 'firebase/firestore';
  import { db } from '@/lib/firebase';
  import { t } from '@/i18n/client';

  // ============================================================
  // State
  // ============================================================

  const TOTAL_STEPS = 3;
  let currentStep = 1;
  let currentUser: import('firebase/auth').User | null = null;

  // DOM refs
  const step1 = document.getElementById('step1')!;
  const step2 = document.getElementById('step2')!;
  const step3 = document.getElementById('step3')!;
  const backBtn = document.getElementById('backBtn') as HTMLButtonElement;
  const nextBtn = document.getElementById('nextBtn') as HTMLButtonElement;
  const skipBtn = document.getElementById('skipBtn')!;
  const progressBar = document.getElementById('progressBar')!;
  const currentStepEl = document.getElementById('currentStep')!;
  const totalStepsEl = document.getElementById('totalSteps')!;
  const errorMsg = document.getElementById('errorMsg') as HTMLDivElement;
  const errorText = document.getElementById('errorText') as HTMLSpanElement;

  totalStepsEl.textContent = String(TOTAL_STEPS);

  // ============================================================
  // Auth guard
  // ============================================================

  authService.onAuthChange(async (firebaseUser) => {
    if (!firebaseUser) {
      window.location.href = '/login';
      return;
    }
    currentUser = firebaseUser;
  });

  // ============================================================
  // Helpers
  // ============================================================

  function hideError(): void {
    errorMsg.classList.add('hidden');
    errorMsg.classList.remove('flex');
  }

  function showError(msg: string): void {
    errorText.textContent = msg;
    errorMsg.classList.remove('hidden');
    errorMsg.classList.add('flex');
  }

  function updateProgress(): void {
    const pct = (currentStep / TOTAL_STEPS) * 100;
    progressBar.style.width = `${pct}%`;
    currentStepEl.textContent = String(currentStep);

    // Show/hide back button
    if (currentStep === 1) {
      backBtn.classList.add('hidden');
    } else {
      backBtn.classList.remove('hidden');
    }

    // Update next button text
    if (currentStep === TOTAL_STEPS) {
      nextBtn.textContent = t('onboarding.finish');
    } else {
      nextBtn.textContent = t('onboarding.next');
    }
  }

  function showStep(step: number): void {
    hideError();
    [step1, step2, step3].forEach((el, i) => {
      el.classList.toggle('hidden', i + 1 !== step);
    });
    currentStep = step;
    updateProgress();
  }

  // ============================================================
  // Collect data from all steps
  // ============================================================

  function collectData(): Record<string, unknown> {
    const birthdate = (document.getElementById('birthdate') as HTMLInputElement).value;
    const height = (document.getElementById('height') as HTMLInputElement).value;
    const weight = (document.getElementById('weight') as HTMLInputElement).value;
    const experience = (document.getElementById('experience') as HTMLSelectElement).value;
    const goals = Array.from(
      document.querySelectorAll('#step1 input[type="checkbox"]:checked')
    ).map((cb) => (cb as HTMLInputElement).value);

    const conditions = (document.getElementById('conditions') as HTMLTextAreaElement).value;
    const medications = (document.getElementById('medications') as HTMLTextAreaElement).value;
    const allergies = (document.getElementById('allergies') as HTMLTextAreaElement).value;
    const injuries = (document.getElementById('injuries') as HTMLTextAreaElement).value;
    const surgery = (document.getElementById('surgery') as HTMLTextAreaElement).value;

    const emergencyName = (document.getElementById('emergencyName') as HTMLInputElement).value;
    const emergencyPhone = (document.getElementById('emergencyPhone') as HTMLInputElement).value;

    return {
      birthdate: birthdate || null,
      height: height ? parseFloat(height) : null,
      initialWeight: weight ? parseFloat(weight) : null,
      experience: experience || null,
      goals: goals.length > 0 ? goals : null,
      conditions: conditions || null,
      medications: medications || null,
      allergies: allergies || null,
      injuries: injuries || null,
      surgery: surgery || null,
      emergencyName: emergencyName || null,
      emergencyPhone: emergencyPhone || null,
    };
  }

  // ============================================================
  // Save to Firestore
  // ============================================================

  async function saveOnboarding(): Promise<boolean> {
    if (!currentUser) {
      showError('Debes iniciar sesión');
      return false;
    }

    const data = collectData();

    // Build medicalProfile object
    const medicalProfile: Record<string, unknown> = {
      updatedAt: serverTimestamp(),
    };

    if (data.birthdate) medicalProfile.birthDate = data.birthdate;
    if (data.height) medicalProfile.height = data.height;
    if (data.initialWeight) medicalProfile.initialWeight = data.initialWeight;
    if (data.experience) medicalProfile.experience = data.experience;
    if (data.goals) medicalProfile.goals = data.goals;
    if (data.conditions) medicalProfile.conditions = data.conditions;
    if (data.medications) medicalProfile.medications = data.medications;
    if (data.allergies) medicalProfile.allergies = data.allergies;
    if (data.injuries) medicalProfile.injuries = data.injuries;
    if (data.surgery) medicalProfile.surgery = data.surgery;
    if (data.emergencyName) medicalProfile.emergencyName = data.emergencyName;
    if (data.emergencyPhone) medicalProfile.emergencyPhone = data.emergencyPhone;

    try {
      await updateDoc(doc(db, 'users', currentUser.uid), {
        medicalProfile,
        onboardingCompleted: true,
        updatedAt: serverTimestamp(),
      });
      return true;
    } catch (err) {
      console.error('[Onboarding] Error saving:', err);
      showError(t('onboarding.error'));
      return false;
    }
  }

  // ============================================================
  // Navigation
  // ============================================================

  nextBtn.addEventListener('click', async () => {
    hideError();

    if (currentStep < TOTAL_STEPS) {
      showStep(currentStep + 1);
    } else {
      // Final step - save
      nextBtn.disabled = true;
      nextBtn.textContent = t('onboarding.saving');

      const success = await saveOnboarding();
      if (success) {
        window.location.href = '/client/dashboard';
      } else {
        nextBtn.disabled = false;
        nextBtn.textContent = t('onboarding.finish');
      }
    }
  });

  backBtn.addEventListener('click', () => {
    if (currentStep > 1) {
      showStep(currentStep - 1);
    }
  });

  skipBtn.addEventListener('click', () => {
    window.location.href = '/client/dashboard';
  });
</script>