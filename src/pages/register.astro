---
import PublicPageLayout from '@/layouts/PublicPageLayout.astro';
import { translations, type Language } from '@/i18n/translations';

const lang = (Astro.url.searchParams.get('lang') as Language) || 'es';
const t = (key: string) => translations[lang]?.[key] || translations['es']?.[key] || key;
---

<PublicPageLayout currentPath="/register">
  <div class="w-full max-w-sm animate-fade-in">
    <!-- Logo -->
    <div class="mb-8 text-center">
      <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-emerald-400 to-emerald-600 shadow-lg shadow-emerald-500/20">
        <svg class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 0 1-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 0 0 6.16-12.12A14.98 14.98 0 0 0 9.631 8.41m5.96 5.96a14.926 14.926 0 0 1-5.841 2.58m-.119-8.54a6 6 0 0 0-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 0 0-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 0 1-2.448-2.448 14.9 14.9 0 0 1 .06-.312m-2.24 2.39a4.493 4.493 0 0 0-1.757 4.306 4.493 4.493 0 0 0 4.306-1.758M16.5 9a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0Z" />
        </svg>
      </div>
      <h1 class="text-2xl font-bold tracking-tight">{t('app.name')}</h1>
      <p class="mt-1 text-sm text-zinc-500">{t('app.tagline')}</p>
    </div>

    <!-- Card -->
    <div class="card-glow rounded-2xl border border-zinc-800/60 bg-zinc-900/80 p-8 backdrop-blur-xl">
      <h2 class="mb-8 text-center text-lg font-semibold">{t('auth.register.title')}</h2>

      <!-- Botón Google -->
      <button
        id="googleBtn"
        class="group flex w-full items-center justify-center gap-3 rounded-xl border border-zinc-700/50 bg-zinc-800/50 px-6 py-3 text-sm font-medium text-zinc-300 transition-all hover:border-zinc-600 hover:bg-zinc-800 hover:text-white"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        {t('auth.google.register')}
      </button>

      <!-- Separador -->
      <div class="my-6 flex items-center gap-3">
        <div class="flex-1 border-t border-zinc-800" />
        <span class="text-xs font-medium uppercase tracking-wider text-zinc-600">{t('auth.or')}</span>
        <div class="flex-1 border-t border-zinc-800" />
      </div>

      <!-- Formulario Email -->
      <form id="registerForm" class="flex flex-col gap-5">
        <div>
          <label for="name" class="mb-1.5 block text-sm font-medium text-zinc-400">{t('auth.name')}</label>
          <input
            id="name"
            type="text"
            placeholder={t('auth.name.placeholder')}
            required
            autocomplete="name"
            class="w-full rounded-xl border border-zinc-700/50 bg-zinc-800/50 px-4 py-3 text-sm text-zinc-100 placeholder-zinc-600 outline-none transition-all focus:border-emerald-500/50 focus:bg-zinc-800 focus:ring-2 focus:ring-emerald-500/10"
          />
          <p id="nameError" class="mt-1 hidden text-xs text-red-400"></p>
        </div>

        <div>
          <label for="email" class="mb-1.5 block text-sm font-medium text-zinc-400">{t('auth.email')}</label>
          <input
            id="email"
            type="email"
            placeholder={t('auth.email.placeholder')}
            required
            autocomplete="email"
            class="w-full rounded-xl border border-zinc-700/50 bg-zinc-800/50 px-4 py-3 text-sm text-zinc-100 placeholder-zinc-600 outline-none transition-all focus:border-emerald-500/50 focus:bg-zinc-800 focus:ring-2 focus:ring-emerald-500/10"
          />
          <p id="emailError" class="mt-1 hidden text-xs text-red-400"></p>
        </div>

        <div>
          <label for="password" class="mb-1.5 block text-sm font-medium text-zinc-400">{t('auth.password')}</label>
          <input
            id="password"
            type="password"
            placeholder={t('auth.password.min')}
            required
            minlength="8"
            autocomplete="new-password"
            class="w-full rounded-xl border border-zinc-700/50 bg-zinc-800/50 px-4 py-3 text-sm text-zinc-100 placeholder-zinc-600 outline-none transition-all focus:border-emerald-500/50 focus:bg-zinc-800 focus:ring-2 focus:ring-emerald-500/10"
          />
          <p id="passwordError" class="mt-1 hidden text-xs text-red-400"></p>
        </div>

        <button
          id="registerBtn"
          type="submit"
          class="flex w-full items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-emerald-500 to-emerald-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-emerald-500/20 transition-all hover:from-emerald-400 hover:to-emerald-500 hover:shadow-emerald-500/30 active:scale-[0.98]"
        >
          {t('auth.register.btn')}
        </button>
      </form>

      <!-- Error -->
      <div id="errorMsg" class="mt-5 hidden items-center gap-2 rounded-xl bg-red-500/10 border border-red-500/20 px-4 py-3 text-sm text-red-400">
        <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
        </svg>
        <span id="errorText"></span>
      </div>
    </div>

    <p class="mt-8 text-center text-sm text-zinc-600">
      {t('auth.has.account')}
      <a href={`/login?lang=${lang}`} class="font-medium text-emerald-400 transition-colors hover:text-emerald-300">{t('auth.login.link')}</a>
    </p>
  </div>
</PublicPageLayout>

<script>
  import { authService } from '@/services/authService';
  import { setUser, setAuthLoading } from '@/stores/authStore';
  import { isValidEmail, isValidPassword, isValidName } from '@/lib/validators';
  import { getStoredLanguage, t } from '@/i18n/client';

  const nameInput = document.getElementById('name') as HTMLInputElement;
  const emailInput = document.getElementById('email') as HTMLInputElement;
  const passwordInput = document.getElementById('password') as HTMLInputElement;
  const registerForm = document.getElementById('registerForm') as HTMLFormElement;
  const registerBtn = document.getElementById('registerBtn') as HTMLButtonElement;
  const googleBtn = document.getElementById('googleBtn') as HTMLButtonElement;
  const errorMsg = document.getElementById('errorMsg') as HTMLDivElement;
  const errorText = document.getElementById('errorText') as HTMLSpanElement;

  const nameError = document.getElementById('nameError') as HTMLParagraphElement;
  const emailError = document.getElementById('emailError') as HTMLParagraphElement;
  const passwordError = document.getElementById('passwordError') as HTMLParagraphElement;

  function showFieldError(el: HTMLParagraphElement, msg: string) {
    el.textContent = msg;
    el.classList.remove('hidden');
  }

  function hideFieldErrors() {
    [nameError, emailError, passwordError].forEach((el) => {
      el.classList.add('hidden');
    });
  }

  function showError(msg: string) {
    errorText.textContent = msg;
    errorMsg.classList.remove('hidden');
    errorMsg.classList.add('flex');
  }

  function hideError() {
    errorMsg.classList.add('hidden');
    errorMsg.classList.remove('flex');
  }

  function redirectByRole(role: string) {
    // New clients go to onboarding, existing roles go to their dashboard
    if (role === 'client') {
      window.location.href = '/onboarding';
      return;
    }
    const routes: Record<string, string> = {
      admin: '/dashboard',
      trainer: '/dashboard',
    };
    window.location.href = routes[role] || '/onboarding';
  }

  registerForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    hideError();
    hideFieldErrors();

    const name = nameInput.value.trim();
    const email = emailInput.value.trim();
    const password = passwordInput.value;

    // Validación en cliente
    let hasError = false;

    const nameValidation = isValidName(name);
    if (!nameValidation.valid) {
      showFieldError(nameError, nameValidation.error!);
      hasError = true;
    }

    if (!isValidEmail(email)) {
      showFieldError(emailError, 'Email inválido');
      hasError = true;
    }

    const passwordValidation = isValidPassword(password);
    if (!passwordValidation.valid) {
      showFieldError(passwordError, passwordValidation.errors[0]!);
      hasError = true;
    }

    if (hasError) return;

    registerBtn.disabled = true;
    registerBtn.innerHTML = `<svg class="h-4 w-4 animate-spin" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg> ${t('auth.loading.register')}`;

    try {
      const user = await authService.registerUser(name, email, password);
      setUser(user);
      setAuthLoading(false);
      redirectByRole(user.role);
    } catch (err: any) {
      const code = err.code || '';
      const messages: Record<string, string> = {
        'auth/email-already-in-use': t('error.email-in-use'),
        'auth/invalid-email': t('error.invalid-email'),
        'auth/weak-password': t('error.weak-password'),
        'auth/operation-not-allowed': t('error.operation-not-allowed'),
      };
      showError(messages[code] || t('error.default.register'));
    } finally {
      registerBtn.disabled = false;
      registerBtn.textContent = t('auth.register.btn');
    }
  });

  googleBtn.addEventListener('click', async () => {
    hideError();
    googleBtn.disabled = true;
    googleBtn.textContent = t('auth.loading.google');

    try {
      const user = await authService.loginWithGoogle();
      setUser(user);
      setAuthLoading(false);
      redirectByRole(user.role);
    } catch (err: any) {
      const code = err.code || '';
      if (code !== 'auth/popup-closed-by-user' && code !== 'auth/cancelled-popup-request') {
        showError(t('error.google.register'));
      }
    } finally {
      googleBtn.disabled = false;
      googleBtn.innerHTML = `
        <svg class="h-5 w-5" viewBox="0 0 24 24">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        ${t('auth.google.register')}
      `;
    }
  });
</script>
